      "viewportScrollY": 3711
    },
    "var_ecb471ae78f8": {
      "type": "variant",
      "label": "Variant 1: Mesmeric Night Garden",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 13640,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --color-ultramarine: #0F2557;\n        --color-gold: #FFD700;\n        --color-cyan: #00FFFF;\n        --color-white: #FFFFFF;\n    }\n\n    body {\n        background-color: var(--color-ultramarine);\n        color: var(--color-white);\n        font-family: 'Inter', sans-serif;\n        overflow-x: clip;\n    }\n\n    .font-mono {\n        font-family: 'JetBrains_Mono', monospace;\n    }\n\n    /* Ticket Stub Notch */\n    .ticket-stub {\n        mask-image: radial-gradient(circle at 0 50%, transparent 15px, black 16px),\n                    radial-gradient(circle at 100% 50%, transparent 15px, black 16px);\n        mask-composite: intersect;\n    }\n\n    /* Marquee Animation */\n    .marquee-container {\n        display: flex;\n        width: max-content;\n        gap: 0;\n        animation: marquee 40s linear infinite;\n    }\n\n    .marquee-card {\n        margin-right: -6rem; /* Deeper overlap */\n        transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);\n        z-index: 1;\n        background: rgba(15, 37, 87, 0.9); /* Solid dark bg behind blur to prevent bleed */\n        backdrop-filter: blur(24px);\n    }\n\n    .marquee-card:hover {\n        transform: translateY(-30px) scale(1.02);\n        z-index: 50;\n        margin-right: 0rem;\n        margin-left: 2rem;\n    }\n\n    @keyframes marquee {\n        to { transform: translateX(-50%); }\n    }\n\n    .marquee-container:hover {\n        animation-play-state: paused;\n    }\n\n    /* Custom Glassmorphism */\n    .glass {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(20px);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n\n    /* Orbiting logic for CTA */\n    .orbit-item {\n        position: absolute;\n        top: 50%;\n        left: 50%;\n        transform-origin: center;\n    }\n\n    /* Scroll progress bar */\n    #progress-bar {\n        position: fixed;\n        top: 0;\n        left: 0;\n        height: 4px;\n        background: var(--color-cyan);\n        box-shadow: 0 0 10px var(--color-cyan);\n        z-index: 100;\n        width: 0%;\n    }\n</style>\n\n<div id=\"progress-bar\" data-kid=\"2\"></div>\n\n\n<main id=\"main-content\" data-kid=\"3\">\n    \n    \n    <section id=\"hero\" class=\"relative w-full h-screen flex flex-col items-center justify-center overflow-hidden\" data-kid=\"4\">\n        <video src=\"https://videos.pexels.com/video-files/15676167/15676167-hd_1920_1080_24fps.mp4\" poster=\"https://images.pexels.com/videos/15676167/pexels-photo-15676167.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute inset-0 w-full h-full object-cover opacity-80 scale-105\" data-kid=\"5\"></video>\n        <div class=\"absolute inset-0 bg-gradient-to-b from-[var(--color-ultramarine)]/60 via-transparent to-[var(--color-ultramarine)]\" data-kid=\"6\"></div>\n        \n        <div class=\"relative z-10 w-full hero-content\" data-kid=\"7\">\n            <h1 class=\"text-[22vw] font-black leading-none tracking-[-0.08em] text-white uppercase select-none text-center\" data-kid=\"8\">\n                HACK47\n            </h1>\n            <div class=\"mt-4 flex flex-col md:flex-row items-center justify-center gap-6 font-mono text-[var(--color-cyan)] text-lg md:text-xl tracking-[0.4em] uppercase\" data-kid=\"9\">\n                <span class=\"bg-black/40 px-4 py-2 backdrop-blur-md\" data-kid=\"10\">Delhi 001</span>\n                <span class=\"hidden md:block opacity-30\" data-kid=\"11\">/</span>\n                <span class=\"bg-black/40 px-4 py-2 backdrop-blur-md\" data-kid=\"12\">16 Builders</span>\n                <span class=\"hidden md:block opacity-30\" data-kid=\"13\">/</span>\n                <span class=\"bg-black/40 px-4 py-2 backdrop-blur-md\" data-kid=\"14\">30 Days Sanctuary</span>\n            </div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 pointer-events-none z-20 overflow-hidden\" data-kid=\"15\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/sparkles.svg\" class=\"sparkle absolute w-16 h-16 mix-blend-exclusion\" style=\"top: 15%; right: 5%; color: var(--color-cyan);\" data-kid=\"16\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/sparkles.svg\" class=\"sparkle absolute w-24 h-24 mix-blend-exclusion\" style=\"bottom: 10%; left: 5%; color: var(--color-gold);\" data-kid=\"17\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/sparkles.svg\" class=\"sparkle absolute w-10 h-10 mix-blend-exclusion\" style=\"top: 50%; left: 2%; color: var(--color-white); opacity: 0.5;\" data-kid=\"18\">\n        </div>\n    </section>\n\n    \n    <section id=\"about\" class=\"relative w-full py-32 overflow-hidden\" data-kid=\"19\">\n        <div class=\"container mx-auto px-6\" data-kid=\"20\">\n            <div class=\"grid lg:grid-cols-2 gap-20 items-center\" data-kid=\"21\">\n                \n                <div class=\"relative flex justify-center about-image\" data-kid=\"22\">\n                    <div class=\"relative w-full max-w-lg aspect-[4/5] rounded-3xl overflow-hidden group\" data-kid=\"23\">\n                        <div class=\"absolute inset-0 bg-radial from-[var(--color-cyan)]/40 to-transparent blur-[120px] opacity-50 group-hover:opacity-100 transition-opacity duration-1000\" data-kid=\"24\"></div>\n                        <img src=\"https://images.unsplash.com/photo-1619626539718-17ec5039c272?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTAwNDR8MHwxfHNlYXJjaHwxfHxnbG93aW5nJTIwaHVtYW4lMjBzaWxob3VldHRlJTIwcmFkaWF0aW5nJTIwbGlnaHR8ZW58MHx8fHwxNzgzMTYwNTk0fDA&ixlib=rb-4.1.0&q=85&w=1200\" alt=\"Building in the AI Era\" class=\"relative z-10 w-full h-full object-cover mix-blend-lighten scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"25\">\n                        \n                        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[200%] h-[200%] bg-gradient-conic from-[var(--color-cyan)]/20 via-transparent to-transparent animate-[spin_10s_linear_infinite] pointer-events-none\" data-kid=\"26\"></div>\n                    </div>\n                </div>\n\n                \n                <div class=\"about-text space-y-12\" data-kid=\"27\">\n                    <div class=\"about-reveal\" data-kid=\"28\">\n                        <h2 class=\"text-7xl md:text-9xl font-black text-white leading-[0.9] tracking-tighter uppercase mb-8\" data-kid=\"29\">\n                            Building in <br data-kid=\"30\">\n                            <span class=\"text-white underline decoration-[var(--color-gold)] decoration-8 underline-offset-[12px]\" data-kid=\"31\">The AI Era</span>\n                        </h2>\n                        <p class=\"text-white/60 text-xl md:text-2xl font-light leading-relaxed max-w-xl\" data-kid=\"32\">\n                            A high-stakes sanctuary for those who build at the frontier. We're assembling 16 obsessed creators for a month of pure, unadulterated execution.\n                        </p>\n                    </div>\n\n                    <div class=\"space-y-6\" data-kid=\"33\">\n                        \n                        <div class=\"glass p-8 rounded-2xl border-l-4 border-l-[var(--color-cyan)] font-mono max-w-lg transform -rotate-1 about-reveal\" data-kid=\"34\">\n                            <div class=\"flex items-center gap-2 mb-4 opacity-50\" data-kid=\"35\">\n                                <div class=\"w-3 h-3 rounded-full bg-red-500/50\" data-kid=\"36\"></div>\n                                <div class=\"w-3 h-3 rounded-full bg-yellow-500/50\" data-kid=\"37\"></div>\n                                <div class=\"w-3 h-3 rounded-full bg-green-500/50\" data-kid=\"38\"></div>\n                                <span class=\"text-xs ml-2\" data-kid=\"39\">manifesto_v1.sh</span>\n                            </div>\n                            <p class=\"text-[var(--color-cyan)] text-lg\" data-kid=\"40\">\n                                &gt; Looking for builders who think in primitives and execute at lightspeed.\n                            </p>\n                        </div>\n\n                        \n                        <div class=\"glass p-8 rounded-2xl border-l-4 border-l-[var(--color-gold)] font-mono max-w-lg lg:ml-12 transform rotate-1 about-reveal\" data-kid=\"41\">\n                            <p class=\"text-white/80 italic leading-relaxed\" data-kid=\"42\">\n                                \"Models are the new raw materials. Agents are the new labor. Infrastructure is the only moat.\"\n                            </p>\n                            <div class=\"mt-4 flex items-center gap-2\" data-kid=\"43\">\n                                <span class=\"bg-[var(--color-gold)]/20 text-[var(--color-gold)] px-2 py-1 text-xs font-bold rounded\" data-kid=\"44\">CORE_FOCUS</span>\n                                <span class=\"text-white/30 text-xs tracking-widest\" data-kid=\"45\">0xDEADBEEF</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"builders\" class=\"relative w-full min-h-screen py-32 flex flex-col justify-center overflow-hidden\" data-kid=\"46\">\n        \n        <video src=\"https://videos.pexels.com/video-files/34424386/14583121_640_360_24fps.mp4\" poster=\"https://images.pexels.com/videos/34424386/abstract-background-blue-and-green-cg-cg-art-34424386.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute inset-0 w-full h-full object-cover opacity-30\" data-kid=\"47\"></video>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-ultramarine)] via-transparent to-[var(--color-ultramarine)]\" data-kid=\"48\"></div>\n\n        <div class=\"relative z-10 px-6 mb-20\" data-kid=\"49\">\n            <h3 class=\"text-white text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none builders-title\" data-kid=\"50\">\n                INVITING <br data-kid=\"51\">THE OBSESSED\n            </h3>\n        </div>\n\n        <div class=\"relative z-10 overflow-hidden py-10\" data-kid=\"52\">\n            <div class=\"marquee-container px-4\" data-kid=\"53\">\n                \n                <div class=\"marquee-card group relative w-[420px] h-[550px] p-10 flex flex-col justify-between ticket-stub border border-white/10 hover:border-[var(--color-gold)] transition-all duration-500\" data-kid=\"54\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"55\">\n                        <span class=\"font-mono text-[var(--color-cyan)] text-xs tracking-[0.3em] uppercase opacity-50\" data-kid=\"56\">TYPE_01</span>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/flower-twirl.svg\" class=\"w-12 h-12 text-[var(--color-gold)] group-hover:rotate-[360deg] transition-transform duration-1000 ease-in-out\" data-kid=\"57\">\n                    </div>\n                    <div data-kid=\"58\">\n                        <h4 class=\"text-white text-5xl font-black mb-4 leading-none uppercase\" data-kid=\"59\">Artist</h4>\n                        <p class=\"text-white/60 text-lg leading-relaxed\" data-kid=\"60\">Visceral experiences at the intersection of human emotion and generative systems.</p>\n                    </div>\n                    <div class=\"border-t border-white/10 pt-6 flex items-center justify-between\" data-kid=\"61\">\n                        <p class=\"font-mono text-[var(--color-gold)] text-[10px] tracking-widest uppercase\" data-kid=\"62\">GEN_ART // SHADERS</p>\n                        <i class=\"ti ti-palette text-xl text-white/20\" data-kid=\"63\"></i>\n                    </div>\n                </div>\n\n                \n                <div class=\"marquee-card group relative w-[420px] h-[550px] p-10 flex flex-col justify-between ticket-stub border border-white/10 hover:border-[var(--color-cyan)] transition-all duration-500\" data-kid=\"64\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"65\">\n                        <span class=\"font-mono text-[var(--color-cyan)] text-xs tracking-[0.3em] uppercase opacity-50\" data-kid=\"66\">TYPE_02</span>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/flower-emblem.svg\" class=\"w-12 h-12 text-white group-hover:rotate-[360deg] transition-transform duration-1000 ease-in-out\" data-kid=\"67\">\n                    </div>\n                    <div data-kid=\"68\">\n                        <h4 class=\"text-white text-5xl font-black mb-4 leading-none uppercase\" data-kid=\"69\">Engineer</h4>\n                        <p class=\"text-white/60 text-lg leading-relaxed\" data-kid=\"70\">Architecting massive-scale intelligence. Turning compute into cognition.</p>\n                    </div>\n                    <div class=\"border-t border-white/10 pt-6 flex items-center justify-between\" data-kid=\"71\">\n                        <p class=\"font-mono text-[var(--color-gold)] text-[10px] tracking-widest uppercase\" data-kid=\"72\">RUST // CUDA // LLM_OPS</p>\n                        <i class=\"ti ti-cpu text-xl text-white/20\" data-kid=\"73\"></i>\n                    </div>\n                </div>\n\n                \n                <div class=\"marquee-card group relative w-[420px] h-[550px] p-10 flex flex-col justify-between ticket-stub border border-white/10 hover:border-[var(--color-gold)] transition-all duration-500\" data-kid=\"74\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"75\">\n                        <span class=\"font-mono text-[var(--color-cyan)] text-xs tracking-[0.3em] uppercase opacity-50\" data-kid=\"76\">TYPE_03</span>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/twirly-flower.svg\" class=\"w-12 h-12 text-[var(--color-gold)] group-hover:rotate-[360deg] transition-transform duration-1000 ease-in-out\" data-kid=\"77\">\n                    </div>\n                    <div data-kid=\"78\">\n                        <h4 class=\"text-white text-5xl font-black mb-4 leading-none uppercase\" data-kid=\"79\">Scientist</h4>\n                        <p class=\"text-white/60 text-lg leading-relaxed\" data-kid=\"80\">Peering into the black box. Discovering the laws of synthetic physics.</p>\n                    </div>\n                    <div class=\"border-t border-white/10 pt-6 flex items-center justify-between\" data-kid=\"81\">\n                        <p class=\"font-mono text-[var(--color-gold)] text-[10px] tracking-widest uppercase\" data-kid=\"82\">ML_RESEARCH // BIO_AI</p>\n                        <i class=\"ti ti-flask text-xl text-white/20\" data-kid=\"83\"></i>\n                    </div>\n                </div>\n\n                \n                <div class=\"marquee-card group relative w-[420px] h-[550px] p-10 flex flex-col justify-between ticket-stub border border-white/10 hover:border-[var(--color-gold)] transition-all duration-500\" data-kid=\"84\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"85\">\n                        <span class=\"font-mono text-[var(--color-cyan)] text-xs tracking-[0.3em] uppercase opacity-50\" data-kid=\"86\">TYPE_01</span>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/flower-twirl.svg\" class=\"w-12 h-12 text-[var(--color-gold)] group-hover:rotate-[360deg] transition-transform duration-1000\" data-kid=\"87\">\n                    </div>\n                    <div data-kid=\"88\">\n                        <h4 class=\"text-white text-5xl font-black mb-4 leading-none uppercase\" data-kid=\"89\">Artist</h4>\n                        <p class=\"text-white/60 text-lg leading-relaxed\" data-kid=\"90\">Visceral experiences at the intersection of human emotion and generative systems.</p>\n                    </div>\n                    <div class=\"border-t border-white/10 pt-6 flex items-center justify-between\" data-kid=\"91\">\n                        <p class=\"font-mono text-[var(--color-gold)] text-[10px] tracking-widest uppercase\" data-kid=\"92\">GEN_ART // SHADERS</p>\n                        <i class=\"ti ti-palette text-xl text-white/20\" data-kid=\"93\"></i>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"logistics\" class=\"relative w-full h-screen grid md:grid-cols-2 grid-rows-2 border-t border-[var(--color-cyan)]\" data-kid=\"94\">\n        \n        <div class=\"relative group overflow-hidden border-r border-b border-[var(--color-cyan)] flex flex-col p-8 md:p-12 logistics-cell\" data-kid=\"95\">\n            <img src=\"https://images.unsplash.com/photo-1464802686167-b939a6910659?auto=format&w=1200&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-5 grayscale group-hover:grayscale-0 group-hover:opacity-20 transition-all duration-1000\" alt=\"Galaxy\" decoding=\"async\" loading=\"lazy\" data-kid=\"96\">\n            <div class=\"relative z-10 w-full h-full flex flex-col justify-between\" data-kid=\"97\">\n                <span class=\"font-mono text-[var(--color-cyan)] text-lg tracking-[0.4em] uppercase\" data-kid=\"98\">TIMELINE_01</span>\n                <h5 class=\"text-white text-7xl md:text-9xl font-black uppercase leading-[0.8] text-right self-end\" data-kid=\"99\">SEPT 15 <br data-kid=\"100\">OCT 15</h5>\n            </div>\n        </div>\n        \n        <div class=\"relative group overflow-hidden border-b border-[var(--color-cyan)] flex flex-col p-8 md:p-12 logistics-cell\" data-kid=\"101\">\n            <img src=\"https://images.unsplash.com/photo-1528722828814-77b9b83aafb2?auto=format&w=1200&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-5 grayscale group-hover:grayscale-0 group-hover:opacity-20 transition-all duration-1000\" alt=\"Stars\" decoding=\"async\" loading=\"lazy\" data-kid=\"102\">\n            <div class=\"relative z-10 w-full h-full flex flex-col justify-between\" data-kid=\"103\">\n                <span class=\"font-mono text-[var(--color-cyan)] text-lg tracking-[0.4em] uppercase\" data-kid=\"104\">LOC_02</span>\n                <h5 class=\"text-white text-7xl md:text-9xl font-black uppercase leading-[0.8] text-right self-end\" data-kid=\"105\">DELHI <br data-kid=\"106\">INDIA</h5>\n            </div>\n        </div>\n        \n        <div class=\"relative group overflow-hidden border-r border-[var(--color-cyan)] flex flex-col p-8 md:p-12 logistics-cell\" data-kid=\"107\">\n            <img src=\"https://images.unsplash.com/photo-1677357623576-7c8aab08da22?auto=format&w=1200&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-5 grayscale group-hover:grayscale-0 group-hover:opacity-20 transition-all duration-1000\" alt=\"Nebula\" decoding=\"async\" loading=\"lazy\" data-kid=\"108\">\n            <div class=\"relative z-10 w-full h-full flex flex-col justify-between\" data-kid=\"109\">\n                <span class=\"font-mono text-[var(--color-cyan)] text-lg tracking-[0.4em] uppercase\" data-kid=\"110\">CAP_03</span>\n                <h5 class=\"text-white text-7xl md:text-9xl font-black uppercase leading-[0.8] text-right self-end\" data-kid=\"111\">16 SPOTS <br data-kid=\"112\">LIMIT</h5>\n            </div>\n        </div>\n        \n        <div class=\"relative group overflow-hidden flex flex-col p-8 md:p-12 logistics-cell\" data-kid=\"113\">\n            <img src=\"https://images.unsplash.com/photo-1502134249126-9f3755a50d78?auto=format&w=1200&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-5 grayscale group-hover:grayscale-0 group-hover:opacity-20 transition-all duration-1000\" alt=\"Cosmos\" decoding=\"async\" loading=\"lazy\" data-kid=\"114\">\n            <div class=\"relative z-10 w-full h-full flex flex-col justify-between\" data-kid=\"115\">\n                <span class=\"font-mono text-[var(--color-cyan)] text-lg tracking-[0.4em] uppercase\" data-kid=\"116\">INV_04</span>\n                <h5 class=\"text-white text-7xl md:text-9xl font-black uppercase leading-[0.8] text-right self-end\" data-kid=\"117\">ZERO <br data-kid=\"118\">COST</h5>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"cta\" class=\"relative w-full min-h-screen flex flex-col items-center justify-center py-32 overflow-hidden\" data-kid=\"119\">\n        <div class=\"absolute inset-0 bg-radial from-[var(--color-cyan)]/10 to-transparent opacity-50\" data-kid=\"120\"></div>\n        \n        <div class=\"relative z-10 text-center mb-16 cta-reveal\" data-kid=\"121\">\n            <p class=\"text-white/40 font-mono tracking-widest mb-4 uppercase\" data-kid=\"122\">TRANSMISSION_END</p>\n            <h2 class=\"text-6xl md:text-8xl font-black text-white uppercase tracking-tighter leading-[0.9]\" data-kid=\"123\">BUILD AT <br data-kid=\"124\">THE SPEED OF <br data-kid=\"125\">COGNITION.</h2>\n        </div>\n\n        <div class=\"relative group cta-button-container\" data-kid=\"126\">\n            \n            <div class=\"absolute inset-0 pointer-events-none orbit-wrapper\" data-kid=\"127\">\n                <div class=\"orbit-item w-full h-full animate-[spin_8s_linear_infinite]\" data-kid=\"128\">\n                    <i class=\"ti ti-rocket text-[var(--color-cyan)] text-5xl absolute -top-16 left-1/2 -translate-x-1/2 drop-shadow-[0_0_15px_var(--color-cyan)]\" data-kid=\"129\"></i>\n                </div>\n                <div class=\"orbit-item w-full h-full animate-[spin_12s_linear_infinite_reverse]\" data-kid=\"130\">\n                    <i class=\"ti ti-cpu text-[var(--color-gold)] text-5xl absolute -bottom-16 left-1/2 -translate-x-1/2 drop-shadow-[0_0_15px_var(--color-gold)]\" data-kid=\"131\"></i>\n                </div>\n                <div class=\"orbit-item w-full h-full animate-[spin_10s_linear_infinite]\" data-kid=\"132\">\n                    <i class=\"ti ti-zap text-white text-5xl absolute top-1/2 -right-16 -translate-y-1/2 drop-shadow-[0_0_15px_white]\" data-kid=\"133\"></i>\n                </div>\n            </div>\n            \n            <button class=\"relative z-10 px-20 py-10 bg-white text-[var(--color-ultramarine)] text-4xl md:text-5xl font-black rounded-full overflow-hidden group hover:scale-110 transition-transform duration-500 shadow-[0_0_80px_rgba(0,255,255,0.3)] cursor-pointer\" data-kid=\"134\">\n                APPLY TO HACK47\n                <div class=\"absolute inset-0 bg-gradient-to-r from-[var(--color-cyan)] to-[var(--color-gold)] translate-y-full group-hover:translate-y-0 transition-transform duration-500 -z-10 opacity-20\" data-kid=\"135\"></div>\n            </button>\n        </div>\n        \n        <footer class=\"absolute bottom-12 text-white/20 font-mono text-xs tracking-widest uppercase\" data-kid=\"136\">\n            © 2024 HACK47 // DELHI_001 // BUILT_IN_AI_ERA\n        </footer>\n    </section>\n\n</main>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"137\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"138\"></script>\n<script type=\"module\" data-kid=\"139\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initialize Lenis\n    const lenis = new Lenis({\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n        smoothWheel: true\n    });\n\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // GSAP Scroll Progress\n    gsap.to(\"#progress-bar\", {\n        width: \"100%\",\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: \"body\",\n            start: \"top top\",\n            end: \"bottom bottom\",\n            scrub: 0.3\n        }\n    });\n\n    // Hero Content Fade In\n    gsap.from(\".hero-content\", {\n        opacity: 0,\n        y: 100,\n        scale: 0.9,\n        duration: 1.5,\n        ease: \"expo.out\"\n    });\n\n    // Sparkles float animation\n    gsap.utils.toArray(\".sparkle\").forEach((spark, i) => {\n        gsap.to(spark, {\n            y: \"random(-100, 100)\",\n            x: \"random(-100, 100)\",\n            rotation: \"random(0, 360)\",\n            duration: \"random(5, 10)\",\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n    });\n\n    // About Section Reveals\n    gsap.from(\".about-image\", {\n        scrollTrigger: {\n            trigger: \"#about\",\n            start: \"top 80%\",\n            toggleActions: \"play none none reverse\"\n        },\n        opacity: 0,\n        x: -100,\n        duration: 1.2,\n        ease: \"power3.out\"\n    });\n\n    gsap.from(\".about-reveal\", {\n        scrollTrigger: {\n            trigger: \"#about\",\n            start: \"top 70%\",\n            toggleActions: \"play none none reverse\"\n        },\n        opacity: 0,\n        y: 50,\n        stagger: 0.2,\n        duration: 1,\n        ease: \"power2.out\"\n    });\n\n    // Builders Title Reveal\n    gsap.from(\".builders-title\", {\n        scrollTrigger: {\n            trigger: \"#builders\",\n            start: \"top 60%\",\n            toggleActions: \"play none none reverse\"\n        },\n        opacity: 0,\n        y: 50,\n        duration: 1,\n        ease: \"power4.out\"\n    });\n\n    // Logistics Grid Reveal\n    gsap.utils.toArray(\".logistics-cell\").forEach((cell, i) => {\n        gsap.from(cell, {\n            scrollTrigger: {\n                trigger: cell,\n                start: \"top 90%\",\n                toggleActions: \"play none none reverse\"\n            },\n            opacity: 0,\n            scale: 0.9,\n            duration: 1,\n            ease: \"back.out(1.7)\"\n        });\n    });\n\n    // CTA Reveal\n    gsap.from(\".cta-reveal\", {\n        scrollTrigger: {\n            trigger: \"#cta\",\n            start: \"top 80%\",\n            toggleActions: \"play none none reverse\"\n        },\n        opacity: 0,\n        y: 50,\n        duration: 1\n    });\n\n    gsap.from(\".cta-button-container\", {\n        scrollTrigger: {\n            trigger: \"#cta\",\n            start: \"top 60%\",\n            toggleActions: \"play none none reverse\"\n        },\n        opacity: 0,\n        scale: 0.5,\n        duration: 1.5,\n        ease: \"elastic.out(1, 0.3)\"\n    });\n\n</script>\n",
