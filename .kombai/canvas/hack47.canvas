    "var_565965dd7cea": {
      "type": "variant",
      "label": "Variant 2: Surreal Cloud Balcony",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 15180,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=JetBrains+Mono:wght@400;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n    :root {\n        --color-sky-blue: #1E88E5;\n        --color-terracotta: #E64A19;\n        --color-tile-green: #43A047;\n        --color-cloud-white: #FAFAFA;\n        --color-ocean-teal: #008080;\n        --font-sans: 'Inter', sans-serif;\n        --font-serif: 'Playfair Display', serif;\n        --font-mono: 'JetBrains Mono', monospace;\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--color-cloud-white);\n        color: #000;\n        overflow-x: clip;\n    }\n\n    .font-pp { font-family: var(--font-sans); }\n    .font-editorial { font-family: var(--font-serif); }\n    .font-mono { font-family: var(--font-mono); }\n\n    .halftone {\n        position: relative;\n    }\n    .halftone::after {\n        content: \"\";\n        position: absolute;\n        inset: 0;\n        background-image: radial-gradient(rgba(0,0,0,0.45) 25%, transparent 25%);\n        background-size: 4px 4px;\n        pointer-events: none;\n        z-index: 5;\n    }\n\n    .grid-bg {\n        background-image: \n            linear-gradient(var(--color-tile-green) 38px, rgba(255,255,255,0.3) 38px),\n            linear-gradient(90deg, var(--color-tile-green) 38px, rgba(255,255,255,0.3) 38px);\n        background-size: 40px 40px;\n        background-color: var(--color-tile-green);\n    }\n\n    .folder-tab {\n        clip-path: polygon(0 0, 85% 0, 100% 100%, 0% 100%);\n    }\n\n    .massive-text {\n        font-size: clamp(8rem, 22vw, 40rem);\n        line-height: 0.75;\n        letter-spacing: -0.06em;\n        text-shadow: 10px 10px 0px rgba(0,0,0,0.1);\n    }\n\n    .realistic-shadow {\n        filter: drop-shadow(30px 50px 25px rgba(0,0,0,0.35));\n    }\n\n    .tape-strip {\n        background: rgba(255, 255, 255, 0.4);\n        backdrop-filter: blur(4px);\n        border: 1px solid rgba(255,255,255,0.3);\n        box-shadow: 2px 2px 5px rgba(0,0,0,0.05);\n        clip-path: polygon(2% 10%, 98% 5%, 95% 90%, 5% 95%, 0% 50%);\n    }\n\n    /* Scroll animations - Removed opacity:0 as per instructions */\n    .reveal { transform: translateY(0); }\n\n    /* CTA Button Inversion */\n    .brutalist-btn:hover {\n        filter: invert(1);\n        background: white;\n        color: black;\n    }\n    .brutalist-btn {\n        transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);\n    }\n\n    .emoji-burst {\n        position: absolute;\n        pointer-events: none;\n        z-index: 50;\n    }\n</style>\n\n\n<main id=\"smooth-wrapper\" data-kid=\"1\">\n    <div id=\"smooth-content\" data-kid=\"2\">\n\n        \n        <section class=\"h-screen flex flex-col items-center justify-center relative overflow-hidden bg-white\" data-kid=\"3\">\n            \n            <div class=\"absolute inset-0 z-0\" data-kid=\"4\">\n                <img src=\"https://images.unsplash.com/photo-1612251557267-4d2ef64bccb5?auto=format&w=1600&q=80&fit=crop\" alt=\"Sky background\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"5\">\n                <div class=\"absolute inset-0 bg-white/30 backdrop-blur-xs\" data-kid=\"6\"></div>\n            </div>\n\n            <div class=\"relative z-10 w-full text-center px-4 flex flex-col items-center justify-center pt-20\" data-kid=\"7\">\n                <h1 class=\"massive-text font-black text-black select-none pointer-events-none uppercase relative z-10 leading-[0.7] drop-shadow-[10px_10px_0px_rgba(0,0,0,0.1)]\" data-kid=\"8\">\n                    HACK<br data-kid=\"9\"><span class=\"inline-block translate-x-[0.05em]\" data-kid=\"10\">47</span>\n                </h1>\n\n                \n                <div id=\"hero-door\" class=\"absolute top-1/2 left-[12%] -translate-y-1/2 w-[22vw] realistic-shadow transform -rotate-3 z-20\" data-kid=\"11\">\n                    <img src=\"https://images.unsplash.com/photo-1660324485557-231ea2147f4c?auto=format&w=800&q=80&fit=crop\" alt=\"Blue Doorway\" class=\"w-full h-auto border-[0.8vw] border-white shadow-2xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n                </div>\n\n                <div id=\"hero-chair\" class=\"absolute bottom-[5%] right-[10%] w-[24vw] realistic-shadow transform rotate-6 z-0\" data-kid=\"13\">\n                    <img src=\"https://images.unsplash.com/photo-1714872245785-674ae3038d21?auto=format&w=800&q=80&fit=crop\" alt=\"Orange Armchair\" class=\"w-full h-auto border-[0.8vw] border-white shadow-2xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"14\">\n                </div>\n            </div>\n\n            \n            <div class=\"absolute bottom-10 left-10 max-w-sm z-30 bg-[#FFD700]/90 p-8 shadow-xl transform rotate-[-1deg] border-t-2 border-white/50 halftone overflow-hidden\" data-kid=\"15\">\n                <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-24 h-6 tape-strip opacity-60\" data-kid=\"16\"></div>\n                <p class=\"font-editorial text-2xl md:text-3xl leading-tight text-black italic relative z-10\" data-kid=\"17\">\n                    \"Where the architecture of the mind meets the vastness of the digital sky.\"\n                </p>\n                <span class=\"absolute bottom-2 right-4 font-mono text-[10px] opacity-30\" data-kid=\"18\">FRAGMENT_H47</span>\n            </div>\n        </section>\n\n        \n        <section class=\"py-40 px-6 md:px-20 grid-bg relative overflow-hidden\" data-kid=\"19\">\n            <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"20\">\n                <div class=\"flex flex-col md:flex-row justify-between items-end mb-32 gap-10\" data-kid=\"21\">\n                    <div class=\"space-y-4\" data-kid=\"22\">\n                        <span class=\"font-mono text-white text-sm bg-black px-2 py-1\" data-kid=\"23\">ENVIRONMENT_V1.0</span>\n                        <h2 class=\"text-7xl md:text-9xl font-black text-white uppercase tracking-tighter\" data-kid=\"24\">The Oasis</h2>\n                    </div>\n                    <p class=\"max-w-md font-editorial text-2xl text-white/90 leading-relaxed text-right md:text-left\" data-kid=\"25\">\n                        A sanctuary for the obsessive builder. Thirty days of unfiltered focus in the heart of Delhi.\n                    </p>\n                </div>\n\n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-24 md:gap-12 items-center\" data-kid=\"26\">\n                    \n                    <div class=\"polaroid-wrapper transform -rotate-6 hover:rotate-0 transition-all duration-500 relative\" data-kid=\"27\">\n                        <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 z-20 w-32 h-8 tape-strip rotate-[-2deg]\" data-kid=\"28\"></div>\n                        <div class=\"bg-white p-5 pb-8 shadow-[30px_30px_0px_rgba(0,0,0,0.1)] border border-black/5\" data-kid=\"29\">\n                            <div class=\"halftone aspect-square overflow-hidden mb-4 border border-black/10\" data-kid=\"30\">\n                                <img src=\"https://images.unsplash.com/photo-1604762524889-3e2fcc145683?auto=format&w=600&q=80&fit=crop\" alt=\"Plant life\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500\" data-kid=\"31\">\n                            </div>\n                            <span class=\"font-mono text-xs text-black uppercase tracking-widest font-bold\" data-kid=\"32\">01_BIOPHILIC_SYNC</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"polaroid-wrapper transform rotate-3 hover:rotate-0 transition-all duration-500 relative mt-20\" data-kid=\"33\">\n                        <div class=\"absolute -top-6 left-1/4 z-20 w-28 h-7 tape-strip rotate-[15deg] opacity-80\" data-kid=\"34\"></div>\n                        <div class=\"bg-white p-5 pb-8 shadow-[30px_30px_0px_rgba(0,0,0,0.1)] border border-black/5\" data-kid=\"35\">\n                            <div class=\"halftone aspect-square overflow-hidden mb-4 border border-black/10\" data-kid=\"36\">\n                                <img src=\"https://images.unsplash.com/photo-1729091331344-a3d5b83556c1?auto=format&w=600&q=80&fit=crop\" alt=\"Ocean view\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500\" data-kid=\"37\">\n                            </div>\n                            <span class=\"font-mono text-xs text-black uppercase tracking-widest font-bold\" data-kid=\"38\">02_HORIZON_SCANNER</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"polaroid-wrapper transform -rotate-2 hover:rotate-0 transition-all duration-500 relative\" data-kid=\"39\">\n                        <div class=\"absolute -top-4 right-1/4 z-20 w-36 h-9 tape-strip rotate-[-12deg] opacity-70\" data-kid=\"40\"></div>\n                        <div class=\"bg-white p-5 pb-8 shadow-[30px_30px_0px_rgba(0,0,0,0.1)] border border-black/5\" data-kid=\"41\">\n                            <div class=\"halftone aspect-square overflow-hidden mb-4 border border-black/10\" data-kid=\"42\">\n                                <img src=\"https://images.unsplash.com/photo-1592150621744-aca64f48394a?auto=format&w=600&q=80&fit=crop\" alt=\"Living space\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500\" data-kid=\"43\">\n                            </div>\n                            <span class=\"font-mono text-xs text-black uppercase tracking-widest font-bold\" data-kid=\"44\">03_NEURAL_REST</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"py-40 bg-white px-6 md:px-20 relative overflow-hidden\" data-kid=\"45\">\n            <div class=\"max-w-5xl mx-auto\" data-kid=\"46\">\n                <div class=\"mb-20\" data-kid=\"47\">\n                    <h2 class=\"text-6xl font-black uppercase tracking-tight mb-4\" data-kid=\"48\">The Residents</h2>\n                    <p class=\"font-mono text-gray-400\" data-kid=\"49\">SELECT CATEGORY TO EXPAND_</p>\n                </div>\n\n                <div class=\"space-y-6\" data-kid=\"50\">\n                    \n                    <div class=\"folder-group relative\" data-folder=\"engineers\" data-kid=\"51\">\n                        <button class=\"w-full text-left focus:outline-hidden\" onclick=\"toggleFolder('engineers')\" data-kid=\"52\">\n                            <div class=\"flex items-end -mb-0.5\" data-kid=\"53\">\n                                <div class=\"bg-[var(--color-terracotta)] text-white px-10 py-4 folder-tab font-black uppercase tracking-widest text-lg z-10\" data-kid=\"54\">Engineers</div>\n                                <div class=\"flex-grow border-b-2 border-black h-4 mb-[2px]\" data-kid=\"55\"></div>\n                            </div>\n                            <div class=\"border-x-2 border-b-2 border-black p-8 hidden content-area bg-white\" data-kid=\"56\">\n                                <div class=\"grid md:grid-cols-2 gap-10\" data-kid=\"57\">\n                                    <div class=\"space-y-6\" data-kid=\"58\">\n                                        <h4 class=\"text-3xl font-black uppercase tracking-tight\" data-kid=\"59\">Systems Architects</h4>\n                                        <p class=\"font-sans text-gray-700 leading-relaxed\" data-kid=\"60\">For those who speak in rust, go, and distributed consensus. We provide high-throughput environments for low-latency thinking.</p>\n                                        <ul class=\"font-mono text-sm space-y-2 border-l-2 border-black pl-4\" data-kid=\"61\">\n                                            <li data-kid=\"62\">> GPU CLUSTER ACCESS</li>\n                                            <li data-kid=\"63\">> 10GBPS FIBER BACKBONE</li>\n                                            <li data-kid=\"64\">> BARE METAL DEDICATION</li>\n                                        </ul>\n                                    </div>\n                                    <div class=\"bg-gray-50 border border-gray-200 p-6 rounded-xs\" data-kid=\"65\">\n                                        <div class=\"flex gap-2 mb-4\" data-kid=\"66\">\n                                            <div class=\"w-3 h-3 rounded-full bg-red-400\" data-kid=\"67\"></div>\n                                            <div class=\"w-3 h-3 rounded-full bg-yellow-400\" data-kid=\"68\"></div>\n                                            <div class=\"w-3 h-3 rounded-full bg-green-400\" data-kid=\"69\"></div>\n                                        </div>\n                                        <pre class=\"font-mono text-xs overflow-x-auto text-blue-600\" data-kid=\"70\"><code>func build_future() {\n    state := os.GetEnv(\"DREAMS\")\n    for {\n        ship(state)\n        iterate()\n    }\n}</code></pre>\n                                    </div>\n                                </div>\n                            </div>\n                        </button>\n                    </div>\n\n                    \n                    <div class=\"folder-group relative\" data-folder=\"artists\" data-kid=\"71\">\n                        <button class=\"w-full text-left focus:outline-hidden\" onclick=\"toggleFolder('artists')\" data-kid=\"72\">\n                            <div class=\"flex items-end -mb-0.5\" data-kid=\"73\">\n                                <div class=\"bg-[var(--color-ocean-teal)] text-white px-10 py-4 folder-tab font-black uppercase tracking-widest text-lg z-10\" data-kid=\"74\">Artists</div>\n                                <div class=\"flex-grow border-b-2 border-black h-4 mb-[2px]\" data-kid=\"75\"></div>\n                            </div>\n                            <div class=\"border-x-2 border-b-2 border-black p-8 hidden content-area bg-white\" data-kid=\"76\">\n                                <div class=\"grid md:grid-cols-2 gap-10\" data-kid=\"77\">\n                                    <div class=\"space-y-6\" data-kid=\"78\">\n                                        <h4 class=\"text-3xl font-black uppercase tracking-tight\" data-kid=\"79\">Creative Visionaries</h4>\n                                        <p class=\"font-sans text-gray-700 leading-relaxed\" data-kid=\"80\">Generative explorers and spatial designers. If you're pushing pixels through neural pipes, this is your canvas.</p>\n                                        <ul class=\"font-mono text-sm space-y-2 border-l-2 border-black pl-4\" data-kid=\"81\">\n                                            <li data-kid=\"82\">> PROJECTION MAPPING LAB</li>\n                                            <li data-kid=\"83\">> SPATIAL AUDIO SUITE</li>\n                                            <li data-kid=\"84\">> 3D PRINTING FARM</li>\n                                        </ul>\n                                    </div>\n                                    <div class=\"flex items-center justify-center bg-gray-50 rounded-xs border border-gray-200\" data-kid=\"85\">\n                                        <i class=\"ti ti-palette text-8xl text-[var(--color-ocean-teal)]/20\" data-kid=\"86\"></i>\n                                    </div>\n                                </div>\n                            </div>\n                        </button>\n                    </div>\n\n                    \n                    <div class=\"folder-group relative\" data-folder=\"entrepreneurs\" data-kid=\"87\">\n                        <button class=\"w-full text-left focus:outline-hidden\" onclick=\"toggleFolder('entrepreneurs')\" data-kid=\"88\">\n                            <div class=\"flex items-end -mb-0.5\" data-kid=\"89\">\n                                <div class=\"bg-[var(--color-tile-green)] text-white px-10 py-4 folder-tab font-black uppercase tracking-widest text-lg z-10\" data-kid=\"90\">Founders</div>\n                                <div class=\"flex-grow border-b-2 border-black h-4 mb-[2px]\" data-kid=\"91\"></div>\n                            </div>\n                            <div class=\"border-x-2 border-b-2 border-black p-8 hidden content-area bg-white\" data-kid=\"92\">\n                                <div class=\"grid md:grid-cols-2 gap-10\" data-kid=\"93\">\n                                    <div class=\"space-y-6\" data-kid=\"94\">\n                                        <h4 class=\"text-3xl font-black uppercase tracking-tight\" data-kid=\"95\">Hyper-Growth Founders</h4>\n                                        <p class=\"font-sans text-gray-700 leading-relaxed\" data-kid=\"96\">Building the engines of the AI era. We provide the leverage you need to scale from 0 to 1 and beyond.</p>\n                                        <ul class=\"font-mono text-sm space-y-2 border-l-2 border-black pl-4\" data-kid=\"97\">\n                                            <li data-kid=\"98\">> INVESTOR NETWORK</li>\n                                            <li data-kid=\"99\">> GO-TO-MARKET CLINICS</li>\n                                            <li data-kid=\"100\">> PRODUCT WAR ROOM</li>\n                                        </ul>\n                                    </div>\n                                    <div class=\"p-6 bg-black text-white font-mono text-xs flex flex-col justify-center\" data-kid=\"101\">\n                                        <div class=\"mb-2\" data-kid=\"102\">MARKET_DOMINATION_INDEX: 99.9%</div>\n                                        <div class=\"w-full bg-white/20 h-2\" data-kid=\"103\">\n                                            <div class=\"bg-[var(--color-tile-green)] w-4/5 h-full\" data-kid=\"104\"></div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"py-32 bg-white relative overflow-hidden\" data-kid=\"105\">\n            <div class=\"max-w-5xl mx-auto relative px-10\" data-kid=\"106\">\n                <div class=\"text-center mb-32\" data-kid=\"107\">\n                    <h2 class=\"text-6xl md:text-8xl font-black uppercase tracking-tighter mb-4\" data-kid=\"108\">The Trajectory</h2>\n                    <p class=\"font-editorial text-2xl italic text-gray-500\" data-kid=\"109\">Trace the milestones of the cohort.</p>\n                </div>\n\n                <div class=\"relative min-h-[1000px]\" data-kid=\"110\">\n                    \n                    <svg class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none overflow-visible\" viewBox=\"0 0 400 1050\" fill=\"none\" data-kid=\"111\">\n                        \n                        <path d=\"M200 0 C190 80, 220 120, 200 200 C150 280, 50 300, 50 450 C50 600, 150 650, 250 750 C350 850, 380 950, 300 1050\" stroke=\"#e2e8f0\" stroke-width=\"4\" stroke-dasharray=\"8 12\" stroke-linecap=\"round\" data-kid=\"112\"></path>\n                        \n                        <path id=\"journey-path\" d=\"M200 0 C190 80, 220 120, 200 200 C150 280, 50 300, 50 450 C50 600, 150 650, 250 750 C350 850, 380 950, 300 1050\" stroke=\"var(--color-sky-blue)\" stroke-width=\"5\" stroke-linecap=\"round\" data-kid=\"113\"></path>\n                    </svg>\n\n                    \n                    <div class=\"space-y-56 relative z-10 pt-32\" data-kid=\"114\">\n                        <div class=\"flex items-center justify-start w-1/2 pr-10 text-right reveal milestone\" data-icon=\"sun\" data-kid=\"115\">\n                            <div class=\"ml-auto\" data-kid=\"116\">\n                                <div class=\"text-[var(--color-sky-blue)] text-5xl mb-3\" data-kid=\"117\"><i class=\"ti ti-sun\" data-kid=\"118\"></i></div>\n                                <h3 class=\"text-3xl font-black uppercase tracking-tighter\" data-kid=\"119\">SEPT 15</h3>\n                                <p class=\"font-mono text-xs text-black font-bold mt-2 uppercase tracking-widest\" data-kid=\"120\">APPLICATION GATEWAY OPENS</p>\n                            </div>\n                        </div>\n\n                        <div class=\"flex items-center justify-end w-full pl-1/2 text-left reveal milestone\" data-icon=\"cloud\" data-kid=\"121\">\n                            <div class=\"w-1/2 pl-10\" data-kid=\"122\">\n                                <div class=\"text-[var(--color-sky-blue)] text-5xl mb-3\" data-kid=\"123\"><i class=\"ti ti-cloud-computing\" data-kid=\"124\"></i></div>\n                                <h3 class=\"text-3xl font-black uppercase tracking-tighter\" data-kid=\"125\">OCT 01</h3>\n                                <p class=\"font-mono text-xs text-black font-bold mt-2 uppercase tracking-widest\" data-kid=\"126\">SELECTIONS TRANSMITTED</p>\n                            </div>\n                        </div>\n\n                        <div class=\"flex items-center justify-start w-1/2 pr-10 text-right reveal milestone\" data-icon=\"sun-high\" data-kid=\"127\">\n                            <div class=\"ml-auto\" data-kid=\"128\">\n                                <div class=\"text-[var(--color-sky-blue)] text-5xl mb-3\" data-kid=\"129\"><i class=\"ti ti-sun-high\" data-kid=\"130\"></i></div>\n                                <h3 class=\"text-3xl font-black uppercase tracking-tighter\" data-kid=\"131\">OCT 15</h3>\n                                <p class=\"font-mono text-xs text-black font-bold mt-2 uppercase tracking-widest\" data-kid=\"132\">MOVE-IN DAY / COMMENCE BUILD</p>\n                            </div>\n                        </div>\n\n                        <div class=\"flex items-center justify-end w-full pl-1/2 text-left reveal milestone\" data-icon=\"rocket\" data-kid=\"133\">\n                            <div class=\"w-1/2 pl-10\" data-kid=\"134\">\n                                <div class=\"text-[var(--color-sky-blue)] text-5xl mb-3\" data-kid=\"135\"><i class=\"ti ti-rocket\" data-kid=\"136\"></i></div>\n                                <h3 class=\"text-3xl font-black uppercase tracking-tighter\" data-kid=\"137\">NOV 15</h3>\n                                <p class=\"font-mono text-xs text-black font-bold mt-2 uppercase tracking-widest\" data-kid=\"138\">DEMO DAY / ASCENSION</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"h-screen relative flex items-center justify-center overflow-hidden cta-container bg-black\" data-kid=\"139\">\n            \n            <video src=\"https://videos.pexels.com/video-files/10238036/10238036-hd_1366_720_60fps.mp4\" poster=\"https://images.pexels.com/videos/10238036/pexels-photo-10238036.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover opacity-60 pointer-events-none grayscale hover:grayscale-0 transition-all duration-700\" data-kid=\"140\">\n            </video>\n\n            <div class=\"relative z-10 text-center px-6\" data-kid=\"141\">\n                <h2 class=\"text-white text-7xl md:text-[10rem] font-black uppercase mb-12 tracking-tighter mix-blend-difference leading-[0.85]\" data-kid=\"142\">\n                    Step<br data-kid=\"143\">Inside\n                </h2>\n                \n                <button class=\"brutalist-btn bg-black text-white px-16 py-8 text-2xl font-black uppercase border-4 border-white tracking-[0.3em] transform hover:scale-110 shadow-[0_0_50px_rgba(0,0,0,0.5)]\" data-kid=\"144\">\n                    Apply Now\n                </button>\n\n                <p class=\"mt-12 font-mono text-white/60 text-sm tracking-widest mix-blend-difference uppercase\" data-kid=\"145\">\n                    Delhi, India | Sept 15 — Oct 15\n                </p>\n            </div>\n        </section>\n\n        \n        <footer class=\"py-20 bg-white border-t-4 border-black px-6 md:px-20\" data-kid=\"146\">\n            <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12\" data-kid=\"147\">\n                <div class=\"space-y-6\" data-kid=\"148\">\n                    <h2 class=\"text-5xl font-black uppercase tracking-tighter\" data-kid=\"149\">HACK 47</h2>\n                    <p class=\"max-w-sm text-gray-500 font-sans\" data-kid=\"150\">A collaborative experiment in high-density building. Built for the era of intelligence.</p>\n                </div>\n                <div class=\"grid grid-cols-2 md:grid-cols-3 gap-16 font-mono text-sm\" data-kid=\"151\">\n                    <div class=\"space-y-4\" data-kid=\"152\">\n                        <p class=\"font-bold border-b border-black pb-2\" data-kid=\"153\">SOCIAL</p>\n                        <ul class=\"space-y-2\" data-kid=\"154\">\n                            <li data-kid=\"155\"><a href=\"#\" class=\"hover:underline\" data-kid=\"156\">TWITTER/X</a></li>\n                            <li data-kid=\"157\"><a href=\"#\" class=\"hover:underline\" data-kid=\"158\">INSTAGRAM</a></li>\n                            <li data-kid=\"159\"><a href=\"#\" class=\"hover:underline\" data-kid=\"160\">LINKEDIN</a></li>\n                        </ul>\n                    </div>\n                    <div class=\"space-y-4\" data-kid=\"161\">\n                        <p class=\"font-bold border-b border-black pb-2\" data-kid=\"162\">NAV</p>\n                        <ul class=\"space-y-2\" data-kid=\"163\">\n                            <li data-kid=\"164\"><a href=\"#\" class=\"hover:underline\" data-kid=\"165\">THE HOUSE</a></li>\n                            <li data-kid=\"166\"><a href=\"#\" class=\"hover:underline\" data-kid=\"167\">THE RESIDENTS</a></li>\n                            <li data-kid=\"168\"><a href=\"#\" class=\"hover:underline\" data-kid=\"169\">APPLICATION</a></li>\n                        </ul>\n                    </div>\n                    <div class=\"space-y-4 col-span-2 md:col-span-1\" data-kid=\"170\">\n                        <p class=\"font-bold border-b border-black pb-2\" data-kid=\"171\">LOCATION</p>\n                        <p class=\"text-gray-400\" data-kid=\"172\">CHATTARPUR, NEW DELHI<br data-kid=\"173\">110074, INDIA</p>\n                    </div>\n                </div>\n            </div>\n            <div class=\"mt-20 pt-10 border-t border-gray-100 flex justify-between items-center font-mono text-[10px] text-gray-400\" data-kid=\"174\">\n                <p data-kid=\"175\">© 2024 HACK 47 LABS. ALL RIGHTS RESERVED.</p>\n                <p data-kid=\"176\">HANDCRAFTED IN THE CLOUDS.</p>\n            </div>\n        </footer>\n\n    </div>\n</main>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"177\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"178\"></script>\n<script type=\"module\" data-kid=\"179\">\n    import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n    import Lenis from \"https://esm.sh/lenis@1\";\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Smooth Scroll\n    const lenis = new Lenis();\n    lenis.on('scroll', ScrollTrigger.update);\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000);\n    });\n    gsap.ticker.lagSmoothing(0);\n\n    // Hero Animations\n    gsap.to(\"#hero-door\", {\n        scrollTrigger: {\n            trigger: \"#hero-door\",\n            start: \"top center\",\n            end: \"bottom top\",\n            scrub: 1\n        },\n        y: -100,\n        rotate: 0,\n        scale: 1.1\n    });\n\n    gsap.to(\"#hero-chair\", {\n        scrollTrigger: {\n            trigger: \"#hero-chair\",\n            start: \"top center\",\n            end: \"bottom top\",\n            scrub: 1\n        },\n        y: 100,\n        rotate: -6,\n        scale: 1.2\n    });\n\n    // Timeline Path Animation - Using GSAP for precise control and length detection\n    const path = document.querySelector(\"#journey-path\");\n    const length = path.getTotalLength();\n    gsap.set(path, { strokeDasharray: length, strokeDashoffset: length });\n\n    gsap.to(path, {\n        strokeDashoffset: 0,\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: path.closest(\"section\"),\n            start: \"top 20%\",\n            end: \"bottom 80%\",\n            scrub: 1\n        }\n    });\n\n    // Reveal milestones\n    document.querySelectorAll(\".reveal\").forEach((el) => {\n        gsap.from(el, {\n            scrollTrigger: {\n                trigger: el,\n                start: \"top 85%\",\n            },\n            opacity: 0,\n            y: 50,\n            duration: 1,\n            ease: \"power3.out\"\n        });\n    });\n\n    // Folder Logic\n    window.toggleFolder = (folderId) => {\n        const folders = document.querySelectorAll('.folder-group');\n        const emojis = {\n            engineers: ['💻', '⚙️', '⚡', '🔬'],\n            artists: ['🎨', '✨', '🌊', '🖼️'],\n            entrepreneurs: ['🚀', '📈', '💎', '💡']\n        };\n\n        folders.forEach(f => {\n            const content = f.querySelector('.content-area');\n            const target = f.getAttribute('data-folder');\n            \n            if (target === folderId) {\n                const isHidden = content.classList.contains('hidden');\n                content.classList.toggle('hidden');\n                \n                if (isHidden) {\n                    // Burst Emojis\n                    for (let i = 0; i < 12; i++) {\n                        createEmoji(f, emojis[folderId][Math.floor(Math.random() * emojis[folderId].length)]);\n                    }\n                }\n            } else {\n                content.classList.add('hidden');\n            }\n        });\n    };\n\n    function createEmoji(parent, char) {\n        const emoji = document.createElement('div');\n        emoji.className = 'emoji-burst text-3xl';\n        emoji.textContent = char;\n        emoji.style.left = Math.random() * 80 + 10 + '%';\n        emoji.style.top = '20%';\n        parent.appendChild(emoji);\n\n        animate(emoji, {\n            y: [0, -150 - Math.random() * 200],\n            x: [(Math.random() - 0.5) * 400],\n            opacity: [1, 0],\n            scale: [0.5, 1.5],\n            rotate: [0, Math.random() * 360]\n        }, {\n            duration: 1.5,\n            easing: \"out\"\n        }).finished.then(() => emoji.remove());\n    }\n</script>\n",
