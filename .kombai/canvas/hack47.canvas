      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@800&family=JetBrains+Mono:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    width: 1200px;\n    height: 630px;\n    background-image: url('https://images.unsplash.com/photo-1603437873662-dc1f44901825?auto=format&w=1200&q=80&fit=crop');\n    background-size: cover;\n    background-position: center;\n    font-family: 'Tahoma', 'Segoe UI', sans-serif;\n    overflow: hidden;\n    position: relative;\n    color: black;\n  }\n\n  /* Desktop Icons */\n  .desktop-icons {\n    position: absolute;\n    top: 40px;\n    left: 40px;\n    display: flex;\n    flex-direction: column;\n    gap: 40px;\n    z-index: 5;\n  }\n\n  .desktop-icon {\n    width: 100px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n  }\n\n  .desktop-icon i {\n    font-size: 48px;\n    color: white;\n    text-shadow: 2px 2px 4px rgba(0,0,0,0.6);\n  }\n\n  .desktop-icon span {\n    color: white;\n    font-size: 14px;\n    margin-top: 8px;\n    text-shadow: 1px 1px 2px rgba(0,0,0,0.8);\n    background: rgba(0, 0, 128, 0.4);\n    padding: 2px 6px;\n    border-radius: 2px;\n  }\n\n  /* Windows Aesthetic */\n  .win-window {\n    position: absolute;\n    top: 45%;\n    left: 55%;\n    transform: translate(-50%, -50%);\n    background: #d4d0c8;\n    border: 2px solid;\n    border-color: #ffffff #808080 #808080 #ffffff;\n    box-shadow: 2px 2px 0px black;\n    width: 750px;\n    z-index: 10;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .win-titlebar {\n    background: linear-gradient(90deg, #0058ee, #3789f8);\n    color: white;\n    padding: 6px 10px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 16px;\n    font-weight: bold;\n    text-shadow: 1px 1px 1px rgba(0,0,0,0.5);\n  }\n\n  .win-controls { display: flex; gap: 3px; }\n\n  .win-btn {\n    width: 24px;\n    height: 24px;\n    background: #d4d0c8;\n    border: 1px solid;\n    border-color: #ffffff #808080 #808080 #ffffff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 12px;\n    color: black;\n    font-weight: bold;\n  }\n\n  .win-btn.close {\n    background: #e81123;\n    color: white;\n  }\n\n  .win-content {\n    padding: 30px;\n    background: white;\n    margin: 4px;\n    border: 1px solid #808080;\n  }\n\n  .hack-title {\n    font-family: 'Syne', sans-serif;\n    font-size: 140px;\n    line-height: 0.8;\n    font-weight: 800;\n    text-transform: uppercase;\n    margin-bottom: 20px;\n    letter-spacing: -6px;\n  }\n\n  .terminal {\n    background: black;\n    color: #FAFF00;\n    padding: 20px;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 16px;\n    border: 1px solid #444;\n  }\n\n  /* Taskbar */\n  .taskbar {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n    height: 45px;\n    background: linear-gradient(to bottom, #245edb, #3f8cf3 9%, #245edb 18%, #245edb 92%, #333);\n    display: flex;\n    align-items: center;\n    z-index: 100;\n  }\n\n  .start-btn {\n    background: linear-gradient(to bottom, #388e3c, #4caf50 50%, #388e3c 100%);\n    border: none;\n    border-top-right-radius: 15px;\n    border-bottom-right-radius: 15px;\n    padding: 0 25px;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    color: white;\n    font-weight: bold;\n    font-size: 18px;\n    font-style: italic;\n    box-shadow: inset -2px 0 5px rgba(0,0,0,0.3);\n  }\n\n  .task-item {\n    background: rgba(255,255,255,0.2);\n    border: 1px solid rgba(255,255,255,0.3);\n    border-radius: 3px;\n    margin: 0 5px;\n    padding: 0 15px;\n    height: 30px;\n    display: flex;\n    align-items: center;\n    color: white;\n    font-size: 14px;\n  }\n</style>\n\n<div class=\"desktop-icons\" data-kid=\"1\">\n  <div class=\"desktop-icon\" data-kid=\"2\">\n    <i class=\"ti ti-device-desktop\" data-kid=\"3\"></i>\n    <span data-kid=\"4\">My Computer</span>\n  </div>\n  <div class=\"desktop-icon\" data-kid=\"5\">\n    <i class=\"ti ti-world\" data-kid=\"6\"></i>\n    <span data-kid=\"7\">Builder Portal</span>\n  </div>\n  <div class=\"desktop-icon\" data-kid=\"8\">\n    <i class=\"ti ti-trash\" data-kid=\"9\"></i>\n    <span data-kid=\"10\">Recycle Bin</span>\n  </div>\n</div>\n\n<div class=\"win-window\" data-kid=\"11\">\n  <div class=\"win-titlebar\" data-kid=\"12\">\n    <span data-kid=\"13\">C:\\SYSTEM\\HACK47_OS.EXE</span>\n    <div class=\"win-controls\" data-kid=\"14\">\n      <div class=\"win-btn\" data-kid=\"15\">_</div>\n      <div class=\"win-btn\" data-kid=\"16\">□</div>\n      <div class=\"win-btn close\" data-kid=\"17\">X</div>\n    </div>\n  </div>\n  <div class=\"win-content\" data-kid=\"18\">\n    <h1 class=\"hack-title\" data-kid=\"19\">HACK<br data-kid=\"20\">47</h1>\n    <div class=\"terminal\" data-kid=\"21\">\n      > INITIALIZING DELHI'S FIRST HACKER HOUSE...<br data-kid=\"22\">\n      > LOCATION: SOUTH DELHI VILLA<br data-kid=\"23\">\n      > SEPT 15 - OCT 15\n    </div>\n  </div>\n</div>\n\n<div class=\"taskbar\" data-kid=\"24\">\n  <div class=\"start-btn\" data-kid=\"25\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" style=\"width: 24px; filter: brightness(200%);\" data-kid=\"26\">\n    start\n  </div>\n  <div class=\"task-item\" data-kid=\"27\">HACK47_OS.EXE</div>\n</div>",
