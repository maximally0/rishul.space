      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@800&display=swap');\n  \n  :root {\n    --win-grey: #d4d0c8;\n    --win-border-light: #ffffff;\n    --win-border-dark: #808080;\n  }\n  \n  body {\n    margin: 0;\n    padding: 0;\n    width: 256px;\n    height: 256px;\n    background-color: #008080; /* Classic Teal background */\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Tahoma', sans-serif;\n  }\n  \n  .floppy-disk {\n    width: 180px;\n    height: 180px;\n    background-color: #2b2b2b;\n    position: relative;\n    border: 2px solid #000;\n    border-radius: 4px;\n    box-shadow: 6px 6px 0px rgba(0,0,0,0.4);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  \n  /* The sliding metal part */\n  .floppy-slider {\n    position: absolute;\n    top: 0;\n    left: 40px;\n    width: 70px;\n    height: 50px;\n    background: linear-gradient(135deg, #e0e0e0, #a0a0a0);\n    border: 1px solid #666;\n    border-top: none;\n    border-bottom-left-radius: 2px;\n    border-bottom-right-radius: 2px;\n  }\n  \n  .floppy-slider::after {\n    content: '';\n    position: absolute;\n    top: 15px;\n    left: 10px;\n    width: 20px;\n    height: 20px;\n    background: #333;\n    border-radius: 2px;\n  }\n  \n  /* The white label */\n  .floppy-label {\n    position: absolute;\n    bottom: 12px;\n    width: 140px;\n    height: 90px;\n    background: white;\n    border: 1px solid #808080;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 5px;\n    box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);\n  }\n  \n  .label-text {\n    font-family: 'Syne', sans-serif;\n    font-size: 64px;\n    font-weight: 800;\n    color: black;\n    line-height: 1;\n    letter-spacing: -2px;\n  }\n  \n  /* Corner notch */\n  .floppy-disk::before {\n    content: '';\n    position: absolute;\n    top: -2px;\n    right: -2px;\n    width: 30px;\n    height: 30px;\n    background: #008080; /* Match body bg to create cut-out effect */\n    border-bottom: 2px solid #000;\n    border-left: 2px solid #000;\n    transform: rotate(45deg) translate(0, -22px);\n  }\n</style>\n<div class=\"floppy-disk\" data-kid=\"1\">\n  <div class=\"floppy-slider\" data-kid=\"2\"></div>\n  <div class=\"floppy-label\" data-kid=\"3\">\n    <span class=\"label-text\" data-kid=\"4\">47</span>\n  </div>\n</div>",
