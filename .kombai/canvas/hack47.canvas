    "var_e1d0fff1a05c": {
      "type": "variant",
      "label": "AGI Dreamscape Variant",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 8998,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<div class=\"bg-[#F4F4F9] text-[#1A0BFF] font-mono selection:bg-[#B2FF05] selection:text-[#1A0BFF]\" data-kid=\"0\">\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n    <style data-kid=\"2\">\n        @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Mrs+Saint+Delafield&family=JetBrains+Mono:wght@400;700&display=swap');\n        \n        :root {\n            --acid-green: #B2FF05;\n            --coral-reef: #FF7B54;\n            --electric-ultramarine: #1A0BFF;\n            --iridescent-pearl: #F4F4F9;\n        }\n\n        .font-oswald { font-family: 'Oswald', sans-serif; }\n        .font-script { font-family: 'Mrs Saint Delafield', cursive; }\n        .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n        .liquid-text {\n            filter: url(#liquid-distortion);\n        }\n\n        .glass-card {\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(40px) saturate(250%);\n            border: 1px solid rgba(255, 255, 255, 0.15);\n            box-shadow: \n                0 30px 60px rgba(0,0,0,0.6),\n                inset 0 0 40px rgba(178, 255, 5, 0.05);\n        }\n\n        .code-rain {\n            background: linear-gradient(180deg, rgba(178, 255, 5, 0) 0%, rgba(178, 255, 5, 0.15) 100%);\n            background-size: 100% 30px;\n            animation: rain 15s linear infinite;\n        }\n\n        @keyframes rain {\n            0% { background-position: 0 0; }\n            100% { background-position: 0 1000px; }\n        }\n\n        .glitch-text {\n            text-shadow: 2px 0 #FF7B54, -2px 0 #1A0BFF;\n            animation: glitch-anim 2s infinite linear alternate-reverse;\n        }\n\n        @keyframes glitch-anim {\n            0% { text-shadow: 1px 0 #FF7B54, -1px 0 #1A0BFF; }\n            50% { text-shadow: -2px 0 #FF7B54, 2px 0 #1A0BFF; }\n            100% { text-shadow: 2px 0 #FF7B54, -2px 0 #1A0BFF; }\n        }\n\n        .scanlines {\n            background: linear-gradient(\n                to bottom,\n                rgba(18, 16, 16, 0) 50%,\n                rgba(0, 0, 0, 0.1) 50%\n            );\n            background-size: 100% 4px;\n            pointer-events: none;\n            z-index: 100;\n        }\n\n        /* Lenis base styles */\n        html.lenis {\n            height: auto;\n        }\n        .lenis-smooth {\n            scroll-behavior: auto !important;\n        }\n        .lenis-smooth [data-lenis-prevent] {\n            overscroll-behavior: contain;\n        }\n        .lenis-stopped {\n            overflow: hidden;\n        }\n    </style>\n\n    \n    <div class=\"fixed inset-0 scanlines opacity-20 pointer-events-none\" data-kid=\"3\"></div>\n\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 p-6 flex justify-between items-start pointer-events-none\" data-kid=\"4\">\n        <div class=\"pointer-events-auto bg-black/80 text-[var(--acid-green)] p-4 border border-[var(--acid-green)]/30 backdrop-blur-md\" data-kid=\"5\">\n            <div class=\"text-xs font-bold\" data-kid=\"6\">[VERSION_2.0] PSYCHEDELIC_DREAMSCAPE</div>\n            <div class=\"text-xl font-oswald tracking-widest uppercase mt-1\" data-kid=\"7\">Delhi Hacker House</div>\n        </div>\n        <div class=\"pointer-events-auto flex flex-col items-end gap-2\" data-kid=\"8\">\n            <div class=\"bg-black/80 text-[var(--acid-green)] px-4 py-2 border border-[var(--acid-green)]/30 backdrop-blur-md\" data-kid=\"9\">\n                <span class=\"text-xs\" data-kid=\"10\">Uptime:</span> <span id=\"uptime-clock\" class=\"font-mono\" data-kid=\"11\">00:00:00:00</span>\n            </div>\n            <div class=\"bg-[var(--acid-green)] text-black px-4 py-1 font-bold text-xs\" data-kid=\"12\">\n                ACCESS_GRANTED\n            </div>\n        </div>\n    </nav>\n\n    \n    <section id=\"hero\" class=\"relative w-full h-screen overflow-hidden flex items-center justify-center bg-black\" data-kid=\"13\">\n        <img src=\"https://images.unsplash.com/photo-1722077079229-4be1b9cbb26b?auto=format&w=1920&q=80&fit=crop\" alt=\"Submerged man in turquoise water\" class=\"absolute inset-0 w-full h-full object-cover brightness-75 scale-110 hero-img\" decoding=\"async\" loading=\"lazy\" data-kid=\"14\">\n        \n        <div class=\"absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-[var(--electric-ultramarine)]/30\" data-kid=\"15\"></div>\n\n        <div class=\"relative z-10 text-center\" data-kid=\"16\">\n            <div class=\"overflow-hidden\" data-kid=\"17\">\n                <h1 class=\"hero-title font-oswald text-[18vw] leading-none text-[var(--acid-green)] liquid-text drop-shadow-[0_0_30px_rgba(178,255,5,0.4)] mix-blend-screen\" data-kid=\"18\">\n                    HACK 47\n                </h1>\n            </div>\n            <div class=\"relative\" data-kid=\"19\">\n                <p class=\"hero-subtitle font-script text-7xl md:text-9xl text-[var(--coral-reef)] -mt-16 md:-mt-24 ml-24 md:ml-48 rotate-[-8deg] drop-shadow-lg\" data-kid=\"20\">\n                    Dreamscape\n                </p>\n            </div>\n        </div>\n\n        <div class=\"absolute bottom-10 left-10 text-[var(--acid-green)]/50 text-xs font-mono uppercase tracking-[0.3em]\" data-kid=\"21\">\n            Submerge into the singularity.\n        </div>\n\n        \n        <div class=\"absolute bottom-10 right-10 flex flex-col items-center gap-4\" data-kid=\"22\">\n            <div class=\"w-px h-24 bg-gradient-to-b from-transparent to-[var(--acid-green)]\" data-kid=\"23\"></div>\n            <div class=\"text-[var(--acid-green)] text-xs rotate-90 origin-right translate-y-4\" data-kid=\"24\">SCROLL_DOWN</div>\n        </div>\n    </section>\n\n    \n    <section id=\"timeline\" class=\"relative w-full min-h-[300vh] bg-black\" data-kid=\"25\">\n        \n        <div class=\"sticky top-0 w-full h-screen overflow-hidden\" data-kid=\"26\">\n            <img src=\"https://images.unsplash.com/photo-1618813690183-c8a0e5de80f0?auto=format&w=1920&q=80&fit=crop\" alt=\"Surreal floral track\" class=\"absolute inset-0 w-full h-full object-cover opacity-80 brightness-90\" decoding=\"async\" loading=\"lazy\" data-kid=\"27\">\n            <div class=\"absolute inset-0 bg-black/40\" data-kid=\"28\"></div>\n            \n            \n            <svg class=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 1440 1024\" fill=\"none\" preserveAspectRatio=\"xMidYMid slice\" data-kid=\"29\">\n                <path id=\"train-track\" d=\"M1440,200 C1000,200 1200,600 720,512 C240,424 400,824 0,824\" stroke=\"var(--acid-green)\" stroke-width=\"3\" fill=\"none\" class=\"opacity-60\" stroke-dasharray=\"8 8\" data-kid=\"30\"></path>\n                \n                \n                <g id=\"retro-train\" class=\"z-30 drop-shadow-[0_0_10px_var(--acid-green)]\" data-kid=\"31\">\n                    <rect width=\"70\" height=\"35\" rx=\"2\" fill=\"var(--acid-green)\" data-kid=\"32\"></rect>\n                    <rect x=\"12\" y=\"6\" width=\"25\" height=\"18\" fill=\"black\" data-kid=\"33\"></rect>\n                    <circle cx=\"18\" cy=\"35\" r=\"7\" fill=\"var(--acid-green)\" data-kid=\"34\"></circle>\n                    <circle cx=\"52\" cy=\"35\" r=\"7\" fill=\"var(--acid-green)\" data-kid=\"35\"></circle>\n                    <text x=\"5\" y=\"-12\" font-family=\"JetBrains Mono\" font-size=\"14\" font-weight=\"bold\" fill=\"var(--acid-green)\" data-kid=\"36\">HACK_EXPRESS_v2</text>\n                </g>\n            </svg>\n        </div>\n\n        \n        <div class=\"relative z-10\" data-kid=\"37\">\n            <div class=\"h-screen flex items-center justify-center timeline-step\" data-kid=\"38\">\n                <div class=\"text-center px-4\" data-kid=\"39\">\n                    <h2 class=\"timeline-title font-oswald text-[12vw] text-white/20 leading-none drop-shadow-2xl\" data-kid=\"40\">THE COMMENCE</h2>\n                    <p class=\"timeline-date font-script text-7xl md:text-9xl text-[var(--coral-reef)] -mt-10 md:-mt-20 drop-shadow-[0_0_15px_rgba(255,123,84,0.4)]\" data-kid=\"41\">Sept 15</p>\n                </div>\n            </div>\n            <div class=\"h-[50vh] flex items-center justify-center\" data-kid=\"42\">\n                 <div class=\"w-1 h-32 bg-gradient-to-b from-transparent via-[var(--acid-green)] to-transparent opacity-20\" data-kid=\"43\"></div>\n            </div>\n            <div class=\"h-screen flex items-center justify-center timeline-step\" data-kid=\"44\">\n                <div class=\"text-center px-4\" data-kid=\"45\">\n                    <h2 class=\"timeline-title font-oswald text-[12vw] text-white/20 leading-none drop-shadow-2xl\" data-kid=\"46\">THE PEAK</h2>\n                    <p class=\"timeline-date font-script text-7xl md:text-9xl text-[var(--acid-green)] -mt-10 md:-mt-20 drop-shadow-[0_0_15px_rgba(178,255,5,0.4)]\" data-kid=\"47\">Oct 01</p>\n                </div>\n            </div>\n            <div class=\"h-[50vh] flex items-center justify-center\" data-kid=\"48\">\n                 <div class=\"w-1 h-32 bg-gradient-to-b from-transparent via-[var(--coral-reef)] to-transparent opacity-20\" data-kid=\"49\"></div>\n            </div>\n            <div class=\"h-screen flex items-center justify-center timeline-step\" data-kid=\"50\">\n                <div class=\"text-center px-4\" data-kid=\"51\">\n                    <h2 class=\"timeline-title font-oswald text-[12vw] text-white/20 leading-none drop-shadow-2xl\" data-kid=\"52\">THE ASCENSION</h2>\n                    <p class=\"timeline-date font-script text-7xl md:text-9xl text-[var(--coral-reef)] -mt-10 md:-mt-20 drop-shadow-[0_0_15px_rgba(255,123,84,0.4)]\" data-kid=\"53\">Oct 15</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"builders\" class=\"relative w-full h-screen flex overflow-hidden bg-black\" data-kid=\"54\">\n        \n        <div class=\"builder-left relative w-full md:w-1/2 h-full overflow-hidden\" style=\"clip-path: polygon(0 0, 100% 0, 85% 100%, 0% 100%); z-index: 10;\" data-kid=\"55\">\n            <img src=\"https://images.unsplash.com/photo-1542235222-30e843cb43a1?auto=format&w=1200&q=80&fit=crop\" alt=\"Hacker mountains\" class=\"absolute inset-0 w-full h-full object-cover grayscale brightness-50 hover:grayscale-0 hover:brightness-100 transition-all duration-1000\" decoding=\"async\" loading=\"lazy\" data-kid=\"56\">\n            <div class=\"absolute inset-0 bg-[var(--electric-ultramarine)]/30 mix-blend-multiply\" data-kid=\"57\"></div>\n            \n            <div class=\"absolute inset-0 flex flex-col justify-end p-20 text-white\" data-kid=\"58\">\n                <div class=\"bg-black/80 p-6 border-l-4 border-[var(--acid-green)] backdrop-blur-md max-w-sm\" data-kid=\"59\">\n                    <h3 class=\"font-oswald text-4xl mb-4 uppercase\" data-kid=\"60\">The Curious</h3>\n                    <p class=\"text-sm font-mono opacity-80 leading-relaxed\" data-kid=\"61\">Built for those who look at the summit and see only a beginning. For the ones who hack not for gain, but for the glint of truth in the code.</p>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"builder-right relative w-full md:w-1/2 h-full bg-black flex items-center justify-center overflow-hidden\" data-kid=\"62\">\n            <div class=\"code-rain absolute inset-0 opacity-15\" data-kid=\"63\"></div>\n            \n            <div class=\"relative z-10 flex flex-col items-center group\" data-kid=\"64\">\n                <div class=\"skull-container relative\" data-kid=\"65\">\n                    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/dread-skull.svg\" alt=\"Hacker Skull\" class=\"w-72 h-72 md:w-96 md:h-96 opacity-40 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700\" style=\"filter: drop-shadow(0 0 20px var(--acid-green));\" data-kid=\"66\">\n                    \n                    <div class=\"absolute top-0 -left-20 w-40 font-mono text-[8px] text-[var(--acid-green)]/30 pointer-events-none select-none\" data-kid=\"67\">\n                        [LOG]: STACK_OVERFLOW<br data-kid=\"68\">[LOG]: HEAP_CORRUPTION<br data-kid=\"69\">[LOG]: ROOT_ACCESS<br data-kid=\"70\">[LOG]: ENCRYPTING...\n                    </div>\n                    <div class=\"absolute bottom-0 -right-20 w-40 font-mono text-[8px] text-[var(--coral-reef)]/30 pointer-events-none select-none text-right\" data-kid=\"71\">\n                        0xDEADBEEF<br data-kid=\"72\">0xCAFEBABE<br data-kid=\"73\">0xFEEDFACE<br data-kid=\"74\">STATUS: OBSESSED\n                    </div>\n                </div>\n                <div class=\"mt-12 font-mono text-[var(--acid-green)] text-lg tracking-[0.5em] group-hover:tracking-[0.8em] transition-all duration-700 uppercase glitch-text\" data-kid=\"75\">\n                    Accessing_Obsession.sh\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 flex items-center justify-center pointer-events-none z-20\" data-kid=\"76\">\n            <h2 class=\"builders-reveal font-script text-[18vw] md:text-[12vw] text-[var(--coral-reef)] leading-none drop-shadow-[0_20px_40px_rgba(0,0,0,0.9)] scale-110\" data-kid=\"77\">\n                Only the obsessed.\n            </h2>\n        </div>\n    </section>\n\n    \n    <section id=\"cta\" class=\"relative w-full h-screen flex items-center justify-center overflow-hidden\" data-kid=\"78\">\n        <video src=\"https://videos.pexels.com/video-files/29535733/12714061_640_360_30fps.mp4\" class=\"absolute inset-0 w-full h-full object-cover scale-110\" autoplay muted loop playsinline poster=\"https://images.pexels.com/videos/29535733/pexels-photo-29535733.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" preload=\"metadata\" data-kid=\"79\"></video>\n        \n        <div class=\"absolute inset-0 bg-black/60 backdrop-blur-md\" data-kid=\"80\"></div>\n\n        \n        <div class=\"cta-card glass-card relative z-10 w-full max-w-4xl p-12 md:p-24 rounded-[4rem] flex flex-col items-center text-center\" data-kid=\"81\">\n            <div class=\"mb-12\" data-kid=\"82\">\n                <h3 class=\"font-oswald text-6xl md:text-8xl text-white mb-4 tracking-tighter uppercase leading-none\" data-kid=\"83\">JOIN THE CULT</h3>\n                <p class=\"font-mono text-[var(--acid-green)] text-sm tracking-widest\" data-kid=\"84\">[INITIALIZING_PROTOCOL_47]</p>\n            </div>\n\n            <div class=\"w-full max-w-xl relative\" data-kid=\"85\">\n                <input type=\"email\" placeholder=\"YOUR_SIGNAL@MATRIX\" class=\"w-full bg-white/5 border-b-2 border-[var(--acid-green)] px-8 py-8 font-mono text-2xl text-white placeholder-white/50 outline-hidden focus:bg-white/10 transition-all rounded-t-2xl\" data-kid=\"86\">\n                \n                <button class=\"absolute right-4 bottom-4 w-24 h-24 bg-[var(--acid-green)] text-[var(--electric-ultramarine)] rounded-full flex items-center justify-center group hover:scale-110 hover:rotate-12 transition-all duration-500 shadow-[0_0_40px_rgba(178,255,5,0.5)] cursor-pointer\" data-kid=\"87\">\n                    <span class=\"text-5xl flex items-center justify-center\" data-kid=\"88\">\n                        <i class=\"ti ti-eye-check group-hover:scale-110 transition-transform\" data-kid=\"89\"></i>\n                    </span>\n                </button>\n            </div>\n\n            \n            <div class=\"mt-16 w-full max-w-2xl font-mono text-[10px] text-[var(--acid-green)]/60 bg-black/40 p-6 rounded-xl border border-white/10 flex flex-wrap justify-center gap-x-12 gap-y-4\" data-kid=\"90\">\n                <div class=\"flex items-center gap-2\" data-kid=\"91\">\n                    <span class=\"text-white/40 font-bold\" data-kid=\"92\">ENC_TYPE:</span> AES_256_GCM\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"93\">\n                    <span class=\"text-white/40\" data-kid=\"94\">PACKET_LOSS:</span> 0.00047%\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"95\">\n                    <span class=\"text-white/40\" data-kid=\"96\">NODE_COUNT:</span> 47_FEDERATED\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"97\">\n                    <span class=\"text-white/40\" data-kid=\"98\">LAST_HACK:</span> DELHI_NORTH\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-black text-[var(--acid-green)]/40 p-10 font-mono text-[10px] border-t border-[var(--acid-green)]/10\" data-kid=\"99\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-10\" data-kid=\"100\">\n            <div data-kid=\"101\">\n                <div data-kid=\"102\">[SERVER]: DELHI_CLUSTER_01</div>\n                <div data-kid=\"103\">[STATUS]: ACTIVE</div>\n                <div data-kid=\"104\">[LOC]: 28.6139° N, 77.2090° E</div>\n            </div>\n            <div class=\"flex gap-10\" data-kid=\"105\">\n                <a href=\"#\" class=\"hover:text-[var(--acid-green)] transition-colors\" data-kid=\"106\">MANIFESTO</a>\n                <a href=\"#\" class=\"hover:text-[var(--acid-green)] transition-colors\" data-kid=\"107\">ACCESS_LOGS</a>\n                <a href=\"#\" class=\"hover:text-[var(--acid-green)] transition-colors\" data-kid=\"108\">ENCRYPTED_SIGNALS</a>\n            </div>\n            <div class=\"text-right\" data-kid=\"109\">\n                <div data-kid=\"110\">© 1997-2047 HACK_CORE_SYSTEMS</div>\n                <div class=\"text-[var(--coral-reef)]\" data-kid=\"111\">ONLY_THE_OBSESSED.EXE</div>\n            </div>\n        </div>\n    </footer>\n\n    \n    <svg class=\"hidden\" aria-hidden=\"true\" data-kid=\"112\">\n        <filter id=\"liquid-distortion\" data-kid=\"113\">\n            <feTurbulence type=\"fractalNoise\" baseFrequency=\"0.012\" numOctaves=\"3\" result=\"noise\" data-kid=\"114\">\n                <animate attributeName=\"baseFrequency\" values=\"0.01;0.015;0.01\" dur=\"8s\" repeatCount=\"indefinite\" data-kid=\"115\"></animate>\n            </feTurbulence>\n            <feDisplacementMap in=\"SourceGraphic\" in2=\"noise\" scale=\"30\" data-kid=\"116\"></feDisplacementMap>\n        </filter>\n    </svg>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"117\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"118\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/MotionPathPlugin.min.js\" data-kid=\"119\"></script>\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"120\">\n    <script type=\"module\" data-kid=\"121\">\n        import Lenis from \"https://esm.sh/lenis@1\"\n        \n        gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);\n\n        // Initialize Smooth Scroll\n        const lenis = new Lenis({\n            duration: 1.2,\n            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n            orientation: 'vertical',\n            gestureOrientation: 'vertical',\n            smoothWheel: true,\n            wheelMultiplier: 1,\n            smoothTouch: false,\n            touchMultiplier: 2,\n            infinite: false,\n        })\n\n        function raf(time) {\n            lenis.raf(time)\n            requestAnimationFrame(raf)\n        }\n        requestAnimationFrame(raf)\n\n        // Uptime Clock\n        function updateClock() {\n            const now = new Date();\n            const uptime = document.getElementById('uptime-clock');\n            uptime.innerText = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}:${String(now.getSeconds()).padStart(2, '0')}:${String(now.getMilliseconds()).padStart(3, '0').slice(0, 2)}`;\n        }\n        setInterval(updateClock, 10);\n\n        // Hero Animations\n        gsap.from(\".hero-img\", {\n            scale: 1.3,\n            duration: 4,\n            ease: \"power2.out\"\n        });\n\n        gsap.from(\".hero-title\", {\n            y: 100,\n            opacity: 0,\n            duration: 2,\n            ease: \"expo.out\",\n            delay: 0.5\n        });\n\n        gsap.from(\".hero-subtitle\", {\n            x: -50,\n            opacity: 0,\n            duration: 2,\n            ease: \"expo.out\",\n            delay: 1\n        });\n\n        // Timeline Train Animation\n        const trainTrack = document.querySelector(\"#train-track\");\n        const train = document.querySelector(\"#retro-train\");\n        \n        if(trainTrack && train) {\n            gsap.to(train, {\n                scrollTrigger: {\n                    trigger: \"#timeline\",\n                    start: \"top top\",\n                    end: \"bottom bottom\",\n                    scrub: 0.5\n                },\n                motionPath: {\n                    path: trainTrack,\n                    align: trainTrack,\n                    alignOrigin: [0.5, 0.5],\n                    autoRotate: true\n                }\n            });\n        }\n\n        // Timeline Reveal Animations\n        gsap.utils.toArray('.timeline-step').forEach((step, i) => {\n            const title = step.querySelector('.timeline-title');\n            const date = step.querySelector('.timeline-date');\n            \n            gsap.fromTo(title, { opacity: 0.05, y: 50 }, {\n                opacity: 0.4, y: 0, scrollTrigger: {\n                    trigger: step,\n                    start: \"top center\",\n                    end: \"bottom center\",\n                    scrub: true\n                }\n            });\n            \n            gsap.fromTo(date, { scale: 0.8, opacity: 0 }, {\n                scale: 1, opacity: 1, scrollTrigger: {\n                    trigger: step,\n                    start: \"top 60%\",\n                    end: \"top 40%\",\n                    scrub: true\n                }\n            });\n        });\n\n        // Builders Reveal\n        gsap.from(\".builders-reveal\", {\n            scrollTrigger: {\n                trigger: \"#builders\",\n                start: \"top 60%\",\n                toggleActions: \"play none none reverse\"\n            },\n            y: 100,\n            opacity: 0,\n            rotate: -5,\n            duration: 2,\n            ease: \"expo.out\"\n        });\n\n        // CTA Card Floating\n        gsap.to(\".cta-card\", {\n            y: -20,\n            repeat: -1,\n            yoyo: true,\n            duration: 3,\n            ease: \"sine.inOut\"\n        });\n\n        // Parallax effects\n        gsap.utils.toArray('section').forEach(section => {\n            const image = section.querySelector('img');\n            if (image) {\n                gsap.to(image, {\n                    yPercent: 10,\n                    ease: \"none\",\n                    scrollTrigger: {\n                        trigger: section,\n                        start: \"top bottom\",\n                        end: \"bottom top\",\n                        scrub: true\n                    }\n                });\n            }\n        });\n\n    </script>\n</div>\n",
