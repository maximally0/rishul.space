      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@800&family=JetBrains+Mono:wght@400;700&display=swap');\n  \n  body {\n    margin: 0;\n    padding: 0;\n    background-color: #008080; /* Teal */\n    height: 630px;\n    width: 1200px;\n    overflow: hidden;\n    font-family: 'Tahoma', sans-serif;\n  }\n\n  /* Bliss-like clouds in BG */\n  .bg-image {\n    position: absolute;\n    width: 100%;\n    height: 100%;\n    background-image: url('https://images.unsplash.com/photo-1603437873662-dc1f44901825?auto=format&w=1200&q=80');\n    background-size: cover;\n    opacity: 0.3;\n  }\n\n  .win-window {\n    position: absolute;\n    background: #d4d0c8;\n    border: 2px solid;\n    border-color: #ffffff #808080 #808080 #ffffff;\n    box-shadow: 2px 2px 0px black;\n    z-index: 10;\n  }\n\n  .win-titlebar {\n    background: linear-gradient(90deg, #0058ee, #3789f8);\n    color: white;\n    padding: 4px 8px;\n    font-size: 14px;\n    font-weight: bold;\n    display: flex;\n    justify-content: space-between;\n  }\n\n  .win-content {\n    background: white;\n    margin: 4px;\n    border: 1px solid #808080;\n    padding: 10px;\n  }\n\n  .main-title {\n    font-family: 'Syne', sans-serif;\n    font-size: 80px;\n    line-height: 0.8;\n    text-transform: uppercase;\n    color: black;\n  }\n\n  .photo-frame {\n    width: 300px;\n    transform: rotate(-3deg);\n  }\n\n  .photo-frame img {\n    width: 100%;\n    height: 180px;\n    object-fit: cover;\n  }\n\n  .error-win {\n    width: 350px;\n    z-index: 50;\n  }\n\n  .clippy-pop {\n    position: absolute;\n    bottom: 20px;\n    right: 20px;\n    width: 150px;\n    z-index: 100;\n  }\n</style>\n\n<div class=\"bg-image\" data-kid=\"1\"></div>\n\n\n<div class=\"win-window top-[50px] left-[50px] w-[500px]\" data-kid=\"2\">\n  <div class=\"win-titlebar\" data-kid=\"3\"><span data-kid=\"4\">HACK47_OS.EXE</span></div>\n  <div class=\"win-content\" data-kid=\"5\">\n    <div class=\"main-title\" data-kid=\"6\">HACK<br data-kid=\"7\">47</div>\n    <p class=\"font-mono text-xs mt-4 bg-black text-[#FAFF00] p-2\" data-kid=\"8\">\n      > LOCATION: SOUTH DELHI VILLA<br data-kid=\"9\">\n      > BUILDERS: 16<br data-kid=\"10\">\n      > DAYS: 30\n    </p>\n  </div>\n</div>\n\n\n<div class=\"win-window top-[80px] right-[100px] photo-frame\" data-kid=\"11\">\n  <div class=\"win-titlebar\" data-kid=\"12\"><span data-kid=\"13\">BALCONY.JPG</span></div>\n  <div class=\"win-content\" data-kid=\"14\">\n    <img src=\"https://images.unsplash.com/photo-1670589953882-b94c9cb380f5?auto=format&w=600&q=80\" alt=\"Villa\" data-kid=\"15\">\n  </div>\n</div>\n\n\n<div class=\"win-window bottom-[100px] left-[400px] photo-frame\" style=\"transform: rotate(2deg);\" data-kid=\"16\">\n  <div class=\"win-titlebar\" data-kid=\"17\"><span data-kid=\"18\">LIVING_ROOM.PNG</span></div>\n  <div class=\"win-content\" data-kid=\"19\">\n    <img src=\"https://images.pexels.com/photos/19977288/pexels-photo-19977288.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" alt=\"Interior\" data-kid=\"20\">\n  </div>\n</div>\n\n\n<div class=\"win-window top-[350px] left-[100px] error-win\" data-kid=\"21\">\n  <div class=\"win-titlebar\" style=\"background: #808080;\" data-kid=\"22\"><span data-kid=\"23\">System Message</span></div>\n  <div class=\"win-content flex gap-4 items-center\" data-kid=\"24\">\n    <span style=\"font-size: 40px;\" data-kid=\"25\">⚠️</span>\n    <div data-kid=\"26\">\n      <p class=\"font-bold text-sm\" data-kid=\"27\">404: Sleep Not Found</p>\n      <p class=\"text-xs\" data-kid=\"28\"> Git history > sleep schedule.</p>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"win-window top-[320px] right-[80px] w-[280px]\" data-kid=\"29\">\n  <div class=\"win-titlebar\" style=\"background: #800000;\" data-kid=\"30\"><span data-kid=\"31\">README.TXT</span></div>\n  <div class=\"win-content font-mono text-[10px]\" data-kid=\"32\">\n    - LAUNDRY.SYS: OK<br data-kid=\"33\">\n    - FOOD.EXE: READY<br data-kid=\"34\">\n    - SLEEP.DLL: OPTIONAL\n  </div>\n</div>\n\n<img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" class=\"clippy-pop\" style=\"filter: brightness(200%) hue-rotate(90deg) contrast(150%);\" data-kid=\"35\">",
