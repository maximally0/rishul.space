      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@800&family=JetBrains+Mono:wght@400;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n    :root {\n        --win-grey: #d4d0c8;\n        --win-blue: #000080;\n        --win-blue-light: #1084d0;\n        --magenta: #FF00FF;\n        --dark-cyan: #008B8B;\n    }\n\n    .font-syne { font-family: 'Syne', sans-serif; }\n    .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n    /* Win95 Chrome Utilities */\n    .win-border {\n        border: 2px solid;\n        border-color: #ffffff #808080 #808080 #ffffff;\n        box-shadow: 1px 1px 0px black;\n    }\n\n    .win-border-sunken {\n        border: 2px solid;\n        border-color: #808080 #ffffff #ffffff #808080;\n    }\n\n    .win-btn-press:active {\n        border-color: #808080 #ffffff #ffffff #808080 !important;\n        padding-top: 2px;\n        padding-left: 2px;\n    }\n\n    .win-titlebar {\n        background: linear-gradient(90deg, var(--win-blue), var(--win-blue-light));\n        color: white;\n        padding: 2px 4px;\n        font-weight: bold;\n        font-size: 11px;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        user-select: none;\n    }\n\n    .win-window {\n        background-color: var(--win-grey);\n    }\n\n    /* Psychedelic Background */\n    .desert-bg {\n        position: fixed;\n        inset: 0;\n        z-index: -1;\n        opacity: 0.45;\n        background-image: url('https://images.pexels.com/photos/26756126/pexels-photo-26756126.jpeg?auto=compress&cs=tinysrgb&w=1280&q=80');\n        background-size: cover;\n        background-position: center;\n        filter: hue-rotate(85deg) saturate(2.5) contrast(1.1);\n    }\n\n    .scanline-overlay {\n        position: fixed;\n        inset: 0;\n        z-index: 1000;\n        pointer-events: none;\n        background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));\n        background-size: 100% 3px, 3px 100%;\n        opacity: 0.25;\n    }\n\n    /* Floating Orbs */\n    .orb {\n        position: absolute;\n        border-radius: 50%;\n        filter: blur(30px);\n        mix-blend-mode: screen;\n        pointer-events: none;\n    }\n\n    /* Glitch Animation */\n    @keyframes glitch-anim {\n        0% { clip-path: inset(40% 0 61% 0); transform: translate(-5px, 2px); }\n        20% { clip-path: inset(92% 0 1% 0); transform: translate(5px, -2px); }\n        40% { clip-path: inset(43% 0 1% 0); transform: translate(-5px, 2px); }\n        60% { clip-path: inset(25% 0 58% 0); transform: translate(5px, -2px); }\n        80% { clip-path: inset(54% 0 7% 0); transform: translate(-5px, 2px); }\n        100% { clip-path: inset(58% 0 43% 0); transform: translate(5px, -2px); }\n    }\n\n    .glitch-btn:hover::before {\n        content: 'GIVE US YOUR SOUL';\n        position: absolute;\n        inset: 0;\n        background: var(--magenta);\n        animation: glitch-anim 0.2s infinite;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        z-index: -1;\n    }\n\n    .terminal-cursor::after {\n        content: '█';\n        display: inline-block;\n        color: #00FF00;\n        animation: blink 0.8s step-end infinite;\n        font-size: 14px;\n        vertical-align: middle;\n        margin-left: 2px;\n    }\n\n    @keyframes blink {\n        50% { opacity: 0; }\n    }\n\n    .retro-scroll-indicator {\n        image-rendering: pixelated;\n        border: 2px solid white;\n        border-right-color: #808080;\n        border-bottom-color: #808080;\n        background: var(--win-grey);\n    }\n</style>\n\n<div class=\"desert-bg\" data-kid=\"1\"></div>\n<div class=\"scanline-overlay\" data-kid=\"2\"></div>\n\n<div id=\"orb-container\" class=\"fixed inset-0 pointer-events-none z-0 overflow-hidden\" data-kid=\"3\">\n    <div class=\"orb w-32 h-32 bg-magenta/50 top-[10%] left-[5%]\" id=\"orb-1\" data-kid=\"4\"></div>\n    <div class=\"orb w-56 h-56 bg-blue-500/40 bottom-[20%] right-[10%]\" id=\"orb-2\" data-kid=\"5\"></div>\n    <div class=\"orb w-28 h-28 bg-yellow-400/30 top-[40%] right-[30%]\" id=\"orb-3\" data-kid=\"6\"></div>\n</div>\n\n<div class=\"relative z-10 w-full max-w-[375px] mx-auto pb-32\" data-kid=\"7\">\n    \n    \n    <section class=\"h-[85vh] flex flex-col items-center justify-center p-4\" data-kid=\"8\">\n        <div class=\"win-window w-full win-border\" id=\"hero-window\" data-kid=\"9\">\n            <div class=\"win-titlebar\" data-kid=\"10\">\n                <div class=\"flex items-center gap-1\" data-kid=\"11\">\n                    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/alien-skull.svg\" class=\"w-4 h-4 invert\" alt=\"Skull icon\" data-kid=\"12\">\n                    <span data-kid=\"13\">C:\\SYSTEM\\HACK47_OS.EXE</span>\n                </div>\n                <div class=\"flex gap-1\" data-kid=\"14\">\n                    <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center\" data-kid=\"15\">_</button>\n                    <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center\" data-kid=\"16\">□</button>\n                    <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center font-bold\" data-kid=\"17\">X</button>\n                </div>\n            </div>\n            <div class=\"p-4 m-1 bg-white border border-gray-600 min-h-[300px] flex flex-col\" data-kid=\"18\">\n                <div class=\"flex-none mb-4\" data-kid=\"19\">\n                    <h1 class=\"font-syne text-[48px] text-black leading-[0.8] tracking-tighter uppercase\" data-kid=\"20\">\n                        HACK<span class=\"text-[var(--magenta)]\" data-kid=\"21\">47</span>\n                    </h1>\n                </div>\n                \n                <div class=\"bg-black text-[#00FF00] p-4 text-xs font-mono leading-relaxed terminal-cursor grow border-inset win-border-sunken\" data-kid=\"22\">\n                    <span id=\"terminal-text\" class=\"whitespace-pre-wrap\" data-kid=\"23\"></span>\n                </div>\n\n                <div class=\"mt-4 p-2 border border-gray-300 flex items-center gap-2 bg-gray-50\" data-kid=\"24\">\n                    <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/floppy-disk.svg\" class=\"w-6 h-6\" alt=\"Floppy disk\" data-kid=\"25\">\n                    <p class=\"text-[9px] font-bold text-gray-500 uppercase\" data-kid=\"26\">SYS_INITIALISED: 1.44MB</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"mt-8 flex flex-col items-center animate-bounce\" data-kid=\"27\">\n            <div class=\"retro-scroll-indicator px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-black shadow-[1px_1px_0px_black]\" data-kid=\"28\">\n                Scroll to Begin\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"min-h-[60vh] flex flex-col items-center justify-start p-4 py-12 relative\" data-kid=\"29\">\n        <div class=\"w-full flex justify-start mb-2\" data-kid=\"30\">\n            <h2 class=\"font-syne text-xl text-white bg-black px-4 py-1 uppercase italic border-2 border-[var(--magenta)] shadow-[3px_3px_0px_var(--magenta)] inline-block\" data-kid=\"31\">\n                House_Gallery\n            </h2>\n        </div>\n\n        <div class=\"relative w-full h-[400px] mt-4\" id=\"gallery-container\" data-kid=\"32\">\n            <div class=\"gallery-card absolute top-2 left-0 w-[95%] win-window win-border z-30\" style=\"transform: rotate(-3deg);\" data-kid=\"33\">\n                <div class=\"win-titlebar !bg-[#808080]\" data-kid=\"34\">\n                    <span data-kid=\"35\">IMG_042_ARENA.JPG</span>\n                    <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center font-bold\" data-kid=\"36\">X</button>\n                </div>\n                <div class=\"p-1 m-1 bg-white border border-gray-600\" data-kid=\"37\">\n                    <img src=\"https://images.pexels.com/photos/36363143/pexels-photo-36363143.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-64 object-cover\" decoding=\"async\" loading=\"lazy\" alt=\"Workspace\" data-kid=\"38\">\n                    <div class=\"p-1.5 border-t border-gray-200 bg-gray-50 flex justify-between items-center text-[8px] font-mono text-gray-500\" data-kid=\"39\">\n                        <span data-kid=\"40\">DRAG TO DISCARD</span>\n                        <span data-kid=\"41\">1/3</span>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"gallery-card absolute top-6 left-6 w-[95%] win-window win-border z-20\" style=\"transform: rotate(2deg);\" data-kid=\"42\">\n                <div class=\"win-titlebar !bg-[#808080]\" data-kid=\"43\">\n                    <span data-kid=\"44\">IMG_019_BUST.BMP</span>\n                    <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center font-bold\" data-kid=\"45\">X</button>\n                </div>\n                <div class=\"p-1 m-1 bg-white border border-gray-600\" data-kid=\"46\">\n                    <img src=\"https://images.unsplash.com/photo-1626711990712-d43b9e05c7ba?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-64 object-cover\" decoding=\"async\" loading=\"lazy\" alt=\"Statue\" data-kid=\"47\">\n                    <div class=\"p-1.5 border-t border-gray-200 bg-gray-50 flex justify-between items-center text-[8px] font-mono text-gray-500\" data-kid=\"48\">\n                        <span data-kid=\"49\">VAPOR_WAVE.SH</span>\n                        <span data-kid=\"50\">2/3</span>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"gallery-card absolute top-10 left-3 w-[95%] win-window win-border z-10\" style=\"transform: rotate(-1deg);\" data-kid=\"51\">\n                <div class=\"win-titlebar !bg-[#808080]\" data-kid=\"52\">\n                    <span data-kid=\"53\">IMG_999_DREAM.JPG</span>\n                    <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center font-bold\" data-kid=\"54\">X</button>\n                </div>\n                <div class=\"p-1 m-1 bg-white border border-gray-600\" data-kid=\"55\">\n                    <img src=\"https://images.pexels.com/photos/10082927/pexels-photo-10082927.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-64 object-cover\" decoding=\"async\" loading=\"lazy\" alt=\"Abstract\" data-kid=\"56\">\n                    <div class=\"p-1.5 border-t border-gray-200 bg-gray-50 flex justify-between items-center text-[8px] font-mono text-gray-500\" data-kid=\"57\">\n                        <span data-kid=\"58\">PEAK_CHAOS</span>\n                        <span data-kid=\"59\">3/3</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"min-h-[50vh] flex flex-col items-center justify-center p-4 py-8\" id=\"protocols-section\" data-kid=\"60\">\n        <div class=\"win-window w-full win-border\" id=\"notepad-window\" data-kid=\"61\">\n            <div class=\"bg-white border-b border-gray-300 p-1 flex items-center justify-between\" data-kid=\"62\">\n                <div class=\"flex items-center gap-1 text-[10px]\" data-kid=\"63\">\n                    <i class=\"ti ti-file-text\" data-kid=\"64\"></i>\n                    <span data-kid=\"65\">README.TXT - Notepad</span>\n                </div>\n                <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center font-bold\" data-kid=\"66\">X</button>\n            </div>\n            <div class=\"flex gap-4 px-2 py-0.5 border-b border-white text-[9px] text-black\" data-kid=\"67\">\n                <span data-kid=\"68\"><u data-kid=\"69\">F</u>ile</span>\n                <span data-kid=\"70\"><u data-kid=\"71\">E</u>dit</span>\n                <span data-kid=\"72\"><u data-kid=\"73\">S</u>earch</span>\n            </div>\n            <div class=\"p-4 m-1 bg-white border border-gray-600 font-mono text-[11px] leading-tight min-h-[250px]\" data-kid=\"74\">\n                <p class=\"mb-4 font-bold border-b border-black pb-1 uppercase\" data-kid=\"75\">RULES OF THE HOUSE</p>\n                <div class=\"space-y-3\" data-kid=\"76\">\n                    <p data-kid=\"77\"><span class=\"bg-[#000080] text-white px-1\" data-kid=\"78\">LAUNDRY</span>: Clean code needs clean socks.</p>\n                    <p data-kid=\"79\"><span class=\"bg-[var(--magenta)] text-white px-1\" data-kid=\"80\">FUEL</span>: High-protein, high-latency meals provided.</p>\n                    <p data-kid=\"81\"><span class=\"bg-red-600 text-white px-1\" data-kid=\"82\">SLEEP</span>: Experimental feature. Use at own risk.</p>\n                    <p data-kid=\"83\"><span class=\"bg-green-600 text-white px-1\" data-kid=\"84\">GIT</span>: Commit often. Push harder.</p>\n                </div>\n                <div class=\"mt-12 text-[9px] text-gray-400\" data-kid=\"85\"> (c) HACK47 MICROSYSTEMS </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"min-h-[50vh] flex flex-col items-center justify-center p-4 py-8\" id=\"cta-section\" data-kid=\"86\">\n        <div class=\"win-window w-full win-border p-1 shadow-[5px_5px_0px_black]\" id=\"warning-dialog\" data-kid=\"87\">\n            <div class=\"win-titlebar !bg-[#808080] mb-1\" data-kid=\"88\">\n                <span data-kid=\"89\">System Critical</span>\n                <button class=\"w-4 h-4 win-window win-border win-btn-press text-[10px] flex items-center justify-center font-bold\" data-kid=\"90\">X</button>\n            </div>\n            <div class=\"bg-white m-1 p-5\" data-kid=\"91\">\n                <div class=\"flex gap-3 items-center mb-6\" data-kid=\"92\">\n                    <i class=\"ti ti-alert-triangle-filled text-4xl text-yellow-500 animate-pulse\" data-kid=\"93\"></i>\n                    <h3 class=\"font-bold text-sm uppercase leading-tight tracking-tighter\" data-kid=\"94\">Warning: Transcendance Imminent. Soul transfer required.</h3>\n                </div>\n                \n                <button class=\"soul-btn w-full bg-[var(--magenta)] border-4 border-white border-r-black border-b-black p-4 text-white font-syne font-black text-xl italic uppercase tracking-tighter relative overflow-hidden glitch-btn win-btn-press\" data-kid=\"95\">\n                    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/pentagram-rose.svg\" class=\"soul-icon absolute -top-1 -right-1 w-12 h-12 opacity-30\" alt=\"Rose\" data-kid=\"96\">\n                    GIVE US YOUR SOUL\n                </button>\n            </div>\n        </div>\n    </section>\n\n</div>\n\n\n<nav class=\"fixed bottom-0 left-0 w-full h-11 bg-[var(--win-grey)] border-t-2 border-white flex items-center px-1 z-[2000] win-border-sunken!\" data-kid=\"97\">\n    <button id=\"start-btn\" class=\"bg-[#388e3c] h-9 px-3 flex items-center gap-1.5 border-2 border-white border-r-gray-950 border-b-gray-950 shadow-[1px_1px_0px_white_inset] text-white font-bold italic text-sm win-btn-press\" data-kid=\"98\">\n        <i class=\"ti ti-menu-2 text-xl leading-none\" data-kid=\"99\"></i>\n        <span class=\"leading-none mt-0.5\" data-kid=\"100\">start</span>\n    </button>\n    \n    <div class=\"mx-1.5 flex gap-1 h-9 items-center grow overflow-hidden\" data-kid=\"101\">\n        <div class=\"bg-[var(--win-grey)] win-border-sunken h-8 px-3 flex items-center text-[10px] font-bold min-w-[100px] bg-white/40 border-r-[#ffffff] border-b-[#ffffff] border-t-[#808080] border-l-[#808080]\" data-kid=\"102\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/alien-skull.svg\" class=\"w-3 h-3 mr-2 opacity-70\" alt=\"icon\" data-kid=\"103\">\n            HACK47_OS\n        </div>\n    </div>\n\n    <div class=\"bg-[var(--win-grey)] win-border-sunken h-8 px-2.5 flex items-center text-[10px] font-mono gap-2 min-w-[80px] bg-black/5\" data-kid=\"104\">\n        <span id=\"pixel-clock\" data-kid=\"105\">12:47 PM</span>\n    </div>\n</nav>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"106\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"107\"></script>\n<script type=\"module\" data-kid=\"108\">\n    import { animate } from 'https://esm.sh/animejs@4';\n    import Lenis from \"https://esm.sh/lenis@1\"\n\n    const lenis = new Lenis()\n    function raf(time) {\n        lenis.raf(time)\n        requestAnimationFrame(raf)\n    }\n    requestAnimationFrame(raf)\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    // GSAP Ambient Orbs\n    gsap.to(\"#orb-1\", { scale: 1.4, x: \"random(-30,30)\", y: \"random(-30,30)\", duration: 3, repeat: -1, yoyo: true, ease: \"power1.inOut\" });\n    gsap.to(\"#orb-2\", { scale: 1.2, x: \"random(-40,40)\", y: \"random(-40,40)\", duration: 4, repeat: -1, yoyo: true, ease: \"power2.inOut\" });\n    gsap.to(\"#orb-3\", { scale: 1.5, opacity: 0.5, duration: 2.5, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n\n    // Terminal Typewriter\n    const terminalEl = document.getElementById('terminal-text');\n    const textToType = \"> INITIALISING...\\n> HACK47_OS LOADED\\n> STATUS: CHAOTIC\\n> UPLOAD SOUL TO BEGIN\";\n    let index = 0;\n    function typeText() {\n        if (index < textToType.length) {\n            terminalEl.textContent += textToType[index];\n            index++;\n            setTimeout(typeText, 40 + Math.random() * 40);\n        }\n    }\n    ScrollTrigger.create({\n        trigger: \"#hero-window\",\n        start: \"top center\",\n        onEnter: () => { if(index === 0) typeText(); },\n        once: true\n    });\n\n    // Anime.js Drag Reveal (Simplified swipe for mobile via click/drag)\n    const cards = document.querySelectorAll('.gallery-card');\n    cards.forEach((card, idx) => {\n        card.addEventListener('click', () => {\n            animate(card, {\n                translateX: [0, 600],\n                rotateZ: [idx % 2 === 0 ? -3 : 3, 25],\n                opacity: [1, 0],\n                duration: 600,\n                easing: 'easeInCubic'\n            }).finished.then(() => {\n                card.style.display = 'none';\n            });\n        });\n    });\n\n    // Warning Dialog Entrance (Anime.js Spring)\n    ScrollTrigger.create({\n        trigger: \"#warning-dialog\",\n        start: \"top 90%\",\n        onEnter: () => {\n            animate(\"#warning-dialog\", {\n                scale: [0.8, 1],\n                translateX: [-20, 0],\n                duration: 1000,\n                easing: 'easeOutElastic(1, .6)'\n            });\n        }\n    });\n\n    // Anime.js Icon Wiggle\n    const soulBtn = document.querySelector('.soul-btn');\n    const soulIcon = document.querySelector('.soul-icon');\n    soulBtn.addEventListener('pointerenter', () => {\n        animate(soulIcon, {\n            rotate: [0, -15, 15, -10, 10, 0],\n            scale: [1, 1.2, 1],\n            duration: 500,\n            easing: 'easeOutQuad'\n        });\n    });\n\n    // Clock\n    function updateClock() {\n        const now = new Date();\n        document.getElementById('pixel-clock').textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });\n    }\n    setInterval(updateClock, 1000);\n    updateClock();\n</script>\n",
