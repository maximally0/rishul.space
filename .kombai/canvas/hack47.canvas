  "nodes": {
    "var_2b95d75d03ce": {
      "type": "variant",
      "label": "Maximalist Nostalgia Variant",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Syne:wght@800&family=JetBrains+Mono:wght@400;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n  --hot-pink: #FF00DD;\n  --electric-yellow: #FAFF00;\n  --win-blue: #005A9E;\n  --win-grey: #d4d0c8;\n  --win-border-light: #ffffff;\n  --win-border-dark: #808080;\n  --taskbar-bg: #ece9d8;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  background-color: #008080; /* Classic Teal */\n  font-family: 'Tahoma', 'Segoe UI', sans-serif;\n  color: black;\n  overflow: hidden; /* Desktop shouldn't scroll, windows float */\n  height: 100vh;\n  width: 100vw;\n}\n\n.font-syne { font-family: 'Syne', sans-serif; font-weight: 800; }\n.font-mono { font-family: 'JetBrains Mono', monospace; }\n\n/* The \"Bliss\" Desktop Background */\n.desktop-environment {\n  position: relative;\n  width: 100%;\n  height: 100vh;\n  background-image: url('https://images.unsplash.com/photo-1603437873662-dc1f44901825?auto=format&w=2000&q=80&fit=crop');\n  background-size: cover;\n  background-position: center;\n  overflow: hidden;\n}\n\n/* Clouds Layer */\n.floating-cloud {\n  position: absolute;\n  pointer-events: none;\n  filter: drop-shadow(0 0 20px rgba(255,255,255,0.5));\n  z-index: 1;\n}\n\n.sun-element {\n  position: absolute;\n  top: 50px;\n  right: 100px;\n  width: 120px;\n  height: 120px;\n  z-index: 2;\n  filter: drop-shadow(0 0 40px #FAFF00);\n}\n\n.flying-bird {\n  position: absolute;\n  width: 40px;\n  z-index: 5;\n}\n\n/* Windows Aesthetic */\n.win-window {\n  position: absolute;\n  background: var(--win-grey);\n  border: 2px solid;\n  border-color: var(--win-border-light) var(--win-border-dark) var(--win-border-dark) var(--win-border-light);\n  box-shadow: 1px 1px 0px black;\n  z-index: 10;\n  display: flex;\n  flex-direction: column;\n  min-width: 200px;\n}\n\n.win-titlebar {\n  background: linear-gradient(90deg, #0058ee, #3789f8);\n  color: white;\n  padding: 3px 6px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  cursor: grab;\n  font-size: 11px;\n  font-weight: bold;\n  text-shadow: 1px 1px 1px rgba(0,0,0,0.5);\n}\n\n.win-controls { display: flex; gap: 2px; }\n\n.win-btn {\n  width: 21px;\n  height: 21px;\n  background: var(--win-grey);\n  border: 1px solid;\n  border-color: var(--win-border-light) var(--win-border-dark) var(--win-border-dark) var(--win-border-light);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 10px;\n  color: black;\n  cursor: pointer;\n  line-height: 1;\n}\n\n.win-btn:active {\n  border-color: var(--win-border-dark) var(--win-border-light) var(--win-border-light) var(--win-border-dark);\n}\n\n.win-btn.close {\n  background: #e81123;\n  color: white;\n  margin-left: 2px;\n}\n\n.win-content {\n  padding: 2px;\n  background: white;\n  margin: 3px;\n  border: 1px solid var(--win-border-dark);\n  overflow-y: auto;\n  max-height: 400px;\n}\n\n/* Desktop Icons */\n.desktop-icons {\n  position: absolute;\n  top: 20px;\n  left: 20px;\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n  z-index: 5;\n}\n\n.desktop-icon {\n  width: 80px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n  cursor: pointer;\n  padding: 10px;\n}\n\n.desktop-icon:hover {\n  background: rgba(255, 255, 255, 0.2);\n  border: 1px dashed white;\n}\n\n.desktop-icon i {\n  font-size: 32px;\n  color: white;\n  text-shadow: 2px 2px 2px rgba(0,0,0,0.5);\n}\n\n.desktop-icon span {\n  color: white;\n  font-size: 11px;\n  margin-top: 5px;\n  text-shadow: 1px 1px 1px rgba(0,0,0,0.8);\n}\n\n/* Taskbar */\n.taskbar {\n  position: fixed;\n  bottom: 0;\n  left: 0;\n  width: 100%;\n  height: 30px;\n  background: linear-gradient(to bottom, #245edb, #3f8cf3 9%, #245edb 18%, #245edb 92%, #333);\n  display: flex;\n  align-items: center;\n  padding: 0;\n  z-index: 1000;\n  box-shadow: 0 -1px 2px rgba(0,0,0,0.5);\n}\n\n.start-btn {\n  background: linear-gradient(to bottom, #388e3c, #4caf50 50%, #388e3c 100%);\n  border: none;\n  border-top-right-radius: 10px;\n  border-bottom-right-radius: 10px;\n  padding: 0 15px;\n  height: 100%;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  color: white;\n  font-weight: bold;\n  font-size: 14px;\n  font-style: italic;\n  cursor: pointer;\n  box-shadow: inset -2px 0 5px rgba(0,0,0,0.3);\n}\n\n.start-btn:hover {\n  filter: brightness(1.1);\n}\n\n.task-item {\n  background: #3c81f3;\n  border-radius: 2px;\n  margin: 0 2px;\n  padding: 0 10px;\n  height: 24px;\n  display: flex;\n  align-items: center;\n  color: white;\n  font-size: 11px;\n  max-width: 150px;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  border: 1px solid rgba(255,255,255,0.3);\n}\n\n.taskbar-clock {\n  margin-left: auto;\n  background: #0997ff;\n  height: 100%;\n  display: flex;\n  align-items: center;\n  padding: 0 15px;\n  color: white;\n  font-size: 11px;\n  box-shadow: inset 2px 0 5px rgba(0,0,0,0.3);\n}\n\n/* Internet Native References */\n.error-text { color: red; font-family: 'Courier New', monospace; font-weight: bold; }\n.blink { animation: blink 1s step-end infinite; }\n@keyframes blink { 50% { opacity: 0; } }\n\n.clippy-buddy {\n  position: absolute;\n  bottom: 50px;\n  right: 50px;\n  width: 120px;\n  z-index: 500;\n  cursor: help;\n}\n\n.clippy-bubble {\n  position: absolute;\n  bottom: 150px;\n  right: 50px;\n  background: #ffffcc;\n  border: 1px solid black;\n  padding: 10px;\n  font-size: 11px;\n  width: 180px;\n  box-shadow: 2px 2px 0px rgba(0,0,0,0.2);\n  display: none;\n}\n</style>\n\n<div class=\"desktop-environment\" data-kid=\"1\">\n  \n  \n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/caro-asercion/heraldic-sun.svg\" class=\"sun-element\" style=\"color: #FAFF00;\" data-kid=\"2\">\n  \n  <div id=\"clouds-container\" data-kid=\"3\"></div>\n  <div id=\"birds-container\" data-kid=\"4\"></div>\n  <div id=\"flowers-container\" data-kid=\"5\"></div>\n\n  \n  <div class=\"desktop-icons\" data-kid=\"6\">\n    <div class=\"desktop-icon\" onclick=\"openWindow('my-computer')\" data-kid=\"7\">\n      <i class=\"ti ti-device-desktop\" data-kid=\"8\"></i>\n      <span data-kid=\"9\">My Computer</span>\n    </div>\n    <div class=\"desktop-icon\" onclick=\"openWindow('recycle-bin')\" data-kid=\"10\">\n      <i class=\"ti ti-trash\" data-kid=\"11\"></i>\n      <span data-kid=\"12\">Recycle Bin</span>\n    </div>\n    <div class=\"desktop-icon\" onclick=\"window.open('https://tally.so/r/hack47', '_blank')\" data-kid=\"13\">\n      <i class=\"ti ti-world\" data-kid=\"14\"></i>\n      <span data-kid=\"15\">Builder Portal</span>\n    </div>\n    <div class=\"desktop-icon\" onclick=\"openWindow('house-photos')\" data-kid=\"16\">\n      <i class=\"ti ti-folder\" data-kid=\"17\"></i>\n      <span data-kid=\"18\">House_Photos</span>\n    </div>\n  </div>\n\n  \n  <div class=\"win-window top-[10%] left-[20%] w-[600px] active-win\" id=\"main-win\" data-kid=\"19\">\n    <div class=\"win-titlebar\" data-kid=\"20\">\n      <span data-kid=\"21\">C:\\SYSTEM\\HACK47_OS.EXE</span>\n      <div class=\"win-controls\" data-kid=\"22\">\n        <div class=\"win-btn\" data-kid=\"23\">_</div>\n        <div class=\"win-btn\" data-kid=\"24\">□</div>\n        <div class=\"win-btn close\" onclick=\"closeWindow('main-win')\" data-kid=\"25\">X</div>\n      </div>\n    </div>\n    <div class=\"win-content p-6\" data-kid=\"26\">\n      <h1 class=\"font-syne text-9xl leading-none tracking-tighter text-black uppercase mb-4\" data-kid=\"27\">HACK<br data-kid=\"28\">47</h1>\n      <div class=\"bg-black text-[var(--electric-yellow)] p-4 font-mono text-sm mb-4\" data-kid=\"29\">\n        > INITIALIZING DELHI'S FIRST HACKER HOUSE... <br data-kid=\"30\">\n        > STATUS: PURE CHAOS DETECTED <br data-kid=\"31\">\n        > LOCATION: SOUTH DELHI VILLA <br data-kid=\"32\">\n        > SEPT 15 - OCT 15\n      </div>\n      <p class=\"font-serif italic text-2xl text-gray-700 leading-tight\" data-kid=\"33\">\n        \"A 30-day residency for 16 builders who care more about their Git history than their sleep schedule.\"\n      </p>\n    </div>\n  </div>\n\n  \n  <div class=\"win-window top-[40%] right-[10%] w-[350px]\" id=\"house-win-1\" data-kid=\"34\">\n    <div class=\"win-titlebar\" data-kid=\"35\">\n      <span data-kid=\"36\">IMG_042_BALCONY.JPG</span>\n      <div class=\"win-controls\" data-kid=\"37\"><div class=\"win-btn close\" onclick=\"closeWindow('house-win-1')\" data-kid=\"38\">X</div></div>\n    </div>\n    <div class=\"win-content\" data-kid=\"39\">\n      <img src=\"https://images.unsplash.com/photo-1670589953882-b94c9cb380f5?auto=format&w=800&q=80&fit=crop\" class=\"w-full\" alt=\"Building exterior by Salman Saqib\" data-kid=\"40\">\n      <p class=\"p-2 text-[10px] font-mono italic\" data-kid=\"41\">View from the 'Thinking Spot'. Birds included.</p>\n    </div>\n  </div>\n\n  <div class=\"win-window bottom-[15%] left-[5%] w-[320px]\" id=\"house-win-2\" data-kid=\"42\">\n    <div class=\"win-titlebar\" data-kid=\"43\">\n      <span data-kid=\"44\">HOUSE_INT_LIVING.PNG</span>\n      <div class=\"win-controls\" data-kid=\"45\"><div class=\"win-btn close\" onclick=\"closeWindow('house-win-2')\" data-kid=\"46\">X</div></div>\n    </div>\n    <div class=\"win-content\" data-kid=\"47\">\n      <img src=\"https://images.pexels.com/photos/19977288/pexels-photo-19977288.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full\" alt=\"Interior by Mochammad Algi\" data-kid=\"48\">\n      <p class=\"p-2 text-[10px] font-mono\" data-kid=\"49\">The Arena. Where 4AM brainwaves happen.</p>\n    </div>\n  </div>\n\n  \n  <div class=\"win-window top-[15%] right-[30%] w-[300px]\" id=\"perks-win\" data-kid=\"50\">\n    <div class=\"win-titlebar bg-[#800000]\" data-kid=\"51\">\n      <span data-kid=\"52\">README_FIRST.TXT</span>\n      <div class=\"win-controls\" data-kid=\"53\"><div class=\"win-btn close\" onclick=\"closeWindow('perks-win')\" data-kid=\"54\">X</div></div>\n    </div>\n    <div class=\"win-content p-4 font-mono text-xs\" data-kid=\"55\">\n      <p class=\"font-bold underline mb-2 uppercase\" data-kid=\"56\">HOUSE PROTOCOLS:</p>\n      <ul class=\"list-none p-0 space-y-2\" data-kid=\"57\">\n        <li data-kid=\"58\">- <span class=\"text-blue-600\" data-kid=\"59\">LAUNDRY.SYS</span>: We wash the socks. You build the robots.</li>\n        <li data-kid=\"60\">- <span class=\"text-green-600\" data-kid=\"61\">FOOD.EXE</span>: High-protein fuel. Optimized for latency.</li>\n        <li data-kid=\"62\">- <span class=\"text-red-600\" data-kid=\"63\">SLEEP.DLL</span>: Optional. Not recommended during demo day.</li>\n      </ul>\n      <div class=\"mt-4 p-2 border border-dashed border-red-500 bg-red-50\" data-kid=\"64\">\n        <p class=\"text-red-600 font-bold blink\" data-kid=\"65\">WARNING:</p>\n        <p data-kid=\"66\">Highly addictive environment. May cause sudden career pivots.</p>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"win-window top-[60%] left-[40%] w-[250px]\" id=\"error-win\" data-kid=\"67\">\n    <div class=\"win-titlebar bg-[#808080]\" data-kid=\"68\">\n      <span data-kid=\"69\">System Error</span>\n      <div class=\"win-controls\" data-kid=\"70\"><div class=\"win-btn close\" onclick=\"closeWindow('error-win')\" data-kid=\"71\">X</div></div>\n    </div>\n    <div class=\"win-content p-4 flex gap-3 items-start\" data-kid=\"72\">\n      <i class=\"ti ti-alert-triangle-filled text-yellow-500 text-3xl\" data-kid=\"73\"></i>\n      <div data-kid=\"74\">\n        <p class=\"text-sm font-bold\" data-kid=\"75\">404: Tribe Not Found?</p>\n        <p class=\"text-xs mt-1\" data-kid=\"76\">If you can't find your tribe in the wild, you must build one at Hack47.</p>\n        <button class=\"mt-3 bg-gray-200 border-2 border-gray-400 px-4 py-1 text-xs\" onclick=\"closeWindow('error-win')\" data-kid=\"77\">OK</button>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"clippy-bubble\" id=\"clippy-msg\" data-kid=\"78\">\n    It looks like you're trying to build the next big thing. Would you like some caffeine and a spot at Hack47 to help with that?\n  </div>\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" class=\"clippy-buddy contrast-200 grayscale brightness-200\" style=\"filter: hue-rotate(90deg);\" onmouseover=\"document.getElementById('clippy-msg').style.display='block'\" onmouseout=\"document.getElementById('clippy-msg').style.display='none'\" data-kid=\"79\">\n\n  \n  <div class=\"taskbar\" data-kid=\"80\">\n    <button class=\"start-btn\" onclick=\"window.open('https://tally.so/r/hack47', '_blank')\" data-kid=\"81\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" class=\"w-5 h-5 brightness-200\" data-kid=\"82\">\n      start\n    </button>\n    \n    <div class=\"task-item\" data-kid=\"83\">HACK47_OS.EXE</div>\n    <div class=\"task-item\" data-kid=\"84\">IMG_042_BALC...</div>\n    <div class=\"task-item\" data-kid=\"85\">README_FIRS...</div>\n    \n    <div class=\"taskbar-clock\" id=\"clock\" data-kid=\"86\">10:47 AM</div>\n  </div>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"87\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/Draggable.min.js\" data-kid=\"88\"></script>\n<script data-kid=\"89\">\n  gsap.registerPlugin(Draggable);\n\n  // Clock Function\n  function updateClock() {\n    const now = new Date();\n    const timeString = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });\n    document.getElementById('clock').innerText = timeString;\n  }\n  setInterval(updateClock, 1000);\n  updateClock();\n\n  // Window Management\n  function closeWindow(id) {\n    const win = document.getElementById(id);\n    gsap.to(win, { scale: 0.8, opacity: 0, duration: 0.2, onComplete: () => {\n      win.style.display = 'none';\n      // Reappear after random time between 10-20s\n      setTimeout(() => {\n        win.style.display = 'flex';\n        gsap.to(win, { scale: 1, opacity: 1, duration: 0.4, ease: \"back.out(1.7)\" });\n      }, 10000 + Math.random() * 10000);\n    }});\n  }\n\n  function openWindow(type) {\n    // Logic for opening new windows from desktop icons\n    alert(\"Opening \" + type + \"... (Wait for system response)\");\n  }\n\n  // Draggable Setup\n  Draggable.create(\".win-window\", {\n    handle: \".win-titlebar\",\n    bounds: \".desktop-environment\",\n    onPress: function() {\n      gsap.set(\".win-window\", { zIndex: 10 });\n      gsap.set(this.target, { zIndex: 100 });\n    }\n  });\n\n  // Generate Nature Assets\n  const cloudsContainer = document.getElementById('clouds-container');\n  const birdsContainer = document.getElementById('birds-container');\n  const flowersContainer = document.getElementById('flowers-container');\n\n  const cloudUrls = [\n    \"https://images.unsplash.com/photo-1603437873662-dc1f44901825?auto=format&w=400&q=80\",\n    \"https://images.unsplash.com/photo-1501630834273-4b5604d2ee31?auto=format&w=400&q=80\"\n  ];\n\n  for (let i = 0; i < 15; i++) {\n    const cloud = document.createElement('img');\n    cloud.src = cloudUrls[i % 2];\n    cloud.className = 'floating-cloud';\n    cloud.style.width = (100 + Math.random() * 200) + 'px';\n    cloud.style.top = (Math.random() * 80) + '%';\n    cloud.style.left = (Math.random() * 100) + '%';\n    cloud.style.opacity = (0.2 + Math.random() * 0.4);\n    cloudsContainer.appendChild(cloud);\n    \n    gsap.to(cloud, {\n      x: \"random(-100, 100)\",\n      y: \"random(-50, 50)\",\n      duration: 20 + Math.random() * 20,\n      repeat: -1,\n      yoyo: true,\n      ease: \"sine.inOut\"\n    });\n  }\n\n  const birdSvg = \"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bird-limb.svg\";\n  for (let i = 0; i < 8; i++) {\n    const bird = document.createElement('img');\n    bird.src = birdSvg;\n    bird.className = 'flying-bird';\n    bird.style.top = (10 + Math.random() * 40) + '%';\n    bird.style.left = \"-50px\";\n    birdsContainer.appendChild(bird);\n    \n    gsap.to(bird, {\n      x: window.innerWidth + 100,\n      y: \"random(-100, 100)\",\n      duration: 15 + Math.random() * 10,\n      repeat: -1,\n      delay: Math.random() * 20,\n      ease: \"none\"\n    });\n  }\n\n  const flowerSvg = \"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/twirly-flower.svg\";\n  for (let i = 0; i < 20; i++) {\n    const flower = document.createElement('img');\n    flower.src = flowerSvg;\n    flower.style.position = 'absolute';\n    flower.style.width = '30px';\n    flower.style.color = '#ff69b4';\n    flower.style.bottom = (Math.random() * 30) + 'px';\n    flower.style.left = (Math.random() * 100) + '%';\n    flower.style.zIndex = '5';\n    flowersContainer.appendChild(flower);\n    \n    gsap.to(flower, {\n      rotation: 360,\n      duration: 10 + Math.random() * 10,\n      repeat: -1,\n      ease: \"none\"\n    });\n  }\n\n  // Floating effect for windows\n  gsap.to(\".win-window\", {\n    y: \"+=15\",\n    duration: 3 + Math.random() * 2,\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\"\n  });\n</script>",
      "comments": [],
      "created": "2026-07-04T10:05:27.236941+00:00",
