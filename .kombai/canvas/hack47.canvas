        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Mono:wght@400;700&family=Inter:wght@400;700&display=swap');\n\n  :root {\n    --color-marigold: #FFB800;\n    --color-indigo: #0B0B2A;\n    --color-cyan: #00F0FF;\n    --color-magenta: #FF007F;\n  }\n\n  body {\n    background-color: var(--color-indigo);\n    color: white;\n    font-family: 'Inter', sans-serif;\n    overflow-x: clip;\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n  .font-mono { font-family: 'Space Mono', monospace; }\n\n  /* CRT Glitch & Overlay */\n  .crt-overlay {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100vw;\n    height: 100vh;\n    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.4) 50%),\n                linear-gradient(90deg, rgba(255, 0, 0, 0.1), rgba(0, 255, 0, 0.05), rgba(0, 0, 255, 0.1));\n    background-size: 100% 8px, 4px 100%;\n    pointer-events: none;\n    z-index: 9999;\n    opacity: 0.4;\n    animation: flicker 0.1s infinite;\n  }\n\n  @keyframes flicker {\n    0% { opacity: 0.35; }\n    50% { opacity: 0.45; }\n    100% { opacity: 0.35; }\n  }\n\n  .glitch-text {\n    position: relative;\n    display: inline-block;\n  }\n\n  .glitch-text::before,\n  .glitch-text::after {\n    content: attr(data-text);\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    opacity: 0.8;\n  }\n\n  .glitch-text::before {\n    color: var(--color-cyan);\n    z-index: -1;\n    animation: glitch-anim 2s infinite linear alternate-reverse;\n  }\n\n  .glitch-text::after {\n    color: var(--color-magenta);\n    z-index: -2;\n    animation: glitch-anim2 3s infinite linear alternate-reverse;\n  }\n\n  @keyframes glitch-anim {\n    0% { clip: rect(44px, 9999px, 56px, 0); transform: skew(0.65deg); }\n    20% { clip: rect(12px, 9999px, 88px, 0); transform: skew(0.1deg); }\n    40% { clip: rect(67px, 9999px, 23px, 0); transform: skew(0.8deg); }\n    60% { clip: rect(89px, 9999px, 45px, 0); transform: skew(0.3deg); }\n    80% { clip: rect(23px, 9999px, 90px, 0); transform: skew(0.5deg); }\n    100% { clip: rect(56px, 9999px, 12px, 0); transform: skew(0.2deg); }\n  }\n\n  @keyframes glitch-anim2 {\n    0% { clip: rect(12px, 9999px, 88px, 0); transform: skew(0.2deg); }\n    20% { clip: rect(67px, 9999px, 23px, 0); transform: skew(0.5deg); }\n    40% { clip: rect(44px, 9999px, 56px, 0); transform: skew(0.1deg); }\n    60% { clip: rect(56px, 9999px, 12px, 0); transform: skew(0.8deg); }\n    80% { clip: rect(89px, 9999px, 45px, 0); transform: skew(0.3deg); }\n    100% { clip: rect(23px, 9999px, 90px, 0); transform: skew(0.6deg); }\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(25px);\n    border: 1px solid rgba(255, 255, 255, 0.2);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8), inset 0 0 20px rgba(0, 240, 255, 0.1);\n  }\n\n  .mask-astronaut {\n    mask-image: linear-gradient(to top, black 60%, transparent 95%), \n                linear-gradient(to bottom, black 90%, transparent 100%),\n                linear-gradient(to left, black 90%, transparent 100%),\n                linear-gradient(to right, black 90%, transparent 100%);\n    mask-composite: intersect;\n  }\n\n  .distorted-text {\n    transform: skewX(-5deg);\n    text-shadow: 2px 2px 0px var(--color-magenta);\n  }\n\n  .horizontal-scroll-container {\n    width: 300vw;\n    display: flex;\n    flex-wrap: nowrap;\n  }\n\n  .portal-btn {\n    clip-path: polygon(10% 0, 100% 0, 90% 100%, 0% 100%);\n  }\n</style>\n\n\n<div id=\"cursor\" class=\"fixed w-8 h-8 rounded-full border border-cyan-400 pointer-events-none z-[10000] mix-blend-difference hidden lg:block\" data-kid=\"1\"></div>\n\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n\n<div class=\"crt-overlay\" data-kid=\"3\"></div>\n\n\n<section id=\"hero\" class=\"relative h-screen overflow-hidden flex items-center justify-center\" data-kid=\"4\">\n  \n  <div class=\"absolute inset-0 z-0 scale-110 saturn-layer\" data-kid=\"5\">\n    <img src=\"https://images.unsplash.com/photo-1706211306706-8f36d91c8379?auto=format&w=1600&q=80&fit=crop\" alt=\"Saturn\" class=\"w-full h-full object-cover opacity-40 grayscale-[0.5] saturate-200\" decoding=\"async\" loading=\"lazy\" data-kid=\"6\">\n  </div>\n\n  \n  <div class=\"absolute inset-0 flex items-center justify-center z-10 pointer-events-none title-layer\" data-kid=\"7\">\n    <h1 class=\"font-anton text-[25vw] leading-none text-white/70 tracking-tighter glitch-text select-none\" data-text=\"HACK 47\" data-kid=\"8\">HACK 47</h1>\n  </div>\n\n  \n  <div class=\"absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-[95vh] z-20 astronaut-layer overflow-visible pointer-events-none mask-astronaut\" data-kid=\"9\">\n    <img src=\"https://images.unsplash.com/photo-1698705486918-9b463adaaae4?auto=format&w=1400&q=80&fit=crop\" alt=\"Astronaut in Marigolds\" class=\"w-full h-full object-contain object-bottom scale-150 origin-bottom\" decoding=\"async\" loading=\"lazy\" data-kid=\"10\">\n  </div>\n\n  \n  <div class=\"absolute inset-0 z-40 pointer-events-none overflow-clip\" data-kid=\"11\">\n    <div class=\"badge-left glass-card absolute left-[15%] top-[25%] px-10 py-4 rounded-full -rotate-12 border-l-4 border-l-cyan-400\" data-kid=\"12\">\n      <span class=\"font-mono text-cyan-400 text-base font-bold tracking-[0.3em] uppercase\" data-kid=\"13\">Delhi's First Hacker House</span>\n    </div>\n    <div class=\"badge-right glass-card absolute right-[15%] bottom-[35%] px-10 py-5 rounded-full rotate-6 border-r-4 border-r-marigold\" data-kid=\"14\">\n      <span class=\"font-mono text-marigold text-2xl font-bold tracking-[0.4em] uppercase\" data-kid=\"15\">Sep 15 - Oct 15</span>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-2\" data-kid=\"16\">\n    <div class=\"w-px h-16 bg-gradient-to-b from-transparent via-cyan-400 to-transparent\" data-kid=\"17\"></div>\n    <span class=\"font-mono text-[10px] tracking-[0.4em] uppercase text-white/50\" data-kid=\"18\">Scroll to warp</span>\n  </div>\n</section>\n\n\n<section id=\"manifest-sticky\" class=\"h-screen bg-indigo-950 overflow-hidden\" data-kid=\"19\">\n  <div class=\"horizontal-scroll-container h-full\" data-kid=\"20\">\n    \n    <div class=\"slide w-screen h-full flex-shrink-0 flex items-center px-[10vw] relative bg-gradient-to-r from-indigo-950 to-indigo-900\" data-kid=\"21\">\n      <div class=\"flex flex-col gap-8 max-w-4xl z-10\" data-kid=\"22\">\n        <h2 class=\"font-anton text-[12vw] text-marigold uppercase leading-[0.8] slide-title tracking-tighter\" data-kid=\"23\">BUILD<br data-kid=\"24\">THE<br data-kid=\"25\">IMPOSSIBLE</h2>\n        <p class=\"font-mono text-cyan-400 text-2xl max-w-md tracking-widest border-l-2 border-cyan-400 pl-6 py-2\" data-kid=\"26\">30 days of high-octane building in the heart of the capital. No sleep, just flow state.</p>\n      </div>\n      <div class=\"absolute right-[5vw] top-1/2 -translate-y-1/2 w-[45vw] h-[60vh] slide-image opacity-40 lg:opacity-100 z-0\" data-kid=\"27\">\n        <img src=\"https://images.unsplash.com/photo-1661546932248-edbc22be2994?auto=format&w=1200&q=80&fit=crop\" alt=\"Vintage Car\" class=\"w-full h-full object-cover rounded-[4rem] shadow-[0_0_120px_rgba(255,184,0,0.3)] saturate-150 rotate-3\" decoding=\"async\" loading=\"lazy\" data-kid=\"28\">\n      </div>\n    </div>\n    \n    \n    <div class=\"slide w-screen h-full flex-shrink-0 flex items-center justify-center relative bg-black/20 overflow-clip\" data-kid=\"29\">\n      <div class=\"text-center w-full\" data-kid=\"30\">\n        <h2 class=\"font-anton text-[15vw] leading-[0.8] text-magenta-500/10 uppercase absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-center w-full\" data-kid=\"31\">REWRITE<br data-kid=\"32\">REALITY</h2>\n        <div class=\"relative z-10 flex flex-col items-center gap-12 px-6\" data-kid=\"33\">\n            <div class=\"glass-card p-12 rounded-[3rem] max-w-2xl text-center border-t-4 border-t-magenta-500\" data-kid=\"34\">\n                <p class=\"font-mono text-3xl leading-relaxed distorted-text\" data-kid=\"35\">\"Hack 47 is not just a house. It's a glitch in the simulation where rules don't apply.\"</p>\n                <div class=\"mt-8 flex justify-center gap-4\" data-kid=\"36\">\n                    <div class=\"w-3 h-3 rounded-full bg-cyan-400\" data-kid=\"37\"></div>\n                    <div class=\"w-3 h-3 rounded-full bg-magenta-500\" data-kid=\"38\"></div>\n                    <div class=\"w-3 h-3 rounded-full bg-marigold\" data-kid=\"39\"></div>\n                </div>\n            </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"slide w-screen h-full flex-shrink-0 flex items-center px-[10vw] bg-indigo-900/10\" data-kid=\"40\">\n        <div class=\"grid grid-cols-2 gap-20 items-center w-full\" data-kid=\"41\">\n            <div class=\"flex flex-col gap-6\" data-kid=\"42\">\n                <span class=\"font-mono text-marigold tracking-tighter text-6xl\" data-kid=\"43\">01 // SELECTIVE</span>\n                <span class=\"font-mono text-cyan-400 tracking-tighter text-6xl\" data-kid=\"44\">02 // INTENSE</span>\n                <span class=\"font-mono text-magenta-500 tracking-tighter text-6xl\" data-kid=\"45\">03 // CHAOTIC</span>\n            </div>\n            <div class=\"font-anton text-[10vw] leading-none text-white text-right\" data-kid=\"46\">THE<br data-kid=\"47\">RULES</div>\n        </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"vibe\" class=\"min-h-screen bg-[#0B0B2A] py-32 px-6 lg:px-20 overflow-hidden\" data-kid=\"48\">\n    <div class=\"flex flex-col lg:flex-row justify-between items-start mb-16 gap-10\" data-kid=\"49\">\n        <h2 class=\"font-anton text-8xl lg:text-[10vw] leading-none tracking-tighter uppercase glitch-text\" data-text=\"THE VIBE\" data-kid=\"50\">THE VIBE</h2>\n        <p class=\"font-mono text-cyan-400 text-right max-w-sm text-base uppercase tracking-widest leading-loose distorted-text\" data-kid=\"51\">Curated chaos. Collective genius. A space flora bloom in the concrete jungle.</p>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-12 gap-10\" data-kid=\"52\">\n        \n        <div class=\"md:col-span-4 md:row-span-1 overflow-hidden rounded-[4rem] group relative border-[12px] border-white/5 -rotate-2\" data-kid=\"53\">\n            <img src=\"https://images.pexels.com/photos/5258195/pexels-photo-5258195.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" alt=\"Astronaut\" data-kid=\"54\">\n            <div class=\"absolute inset-0 bg-marigold/70 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center backdrop-blur-md\" data-kid=\"55\">\n                <span class=\"font-anton text-7xl text-indigo-950 -rotate-12 tracking-tighter\" data-kid=\"56\">SURREAL</span>\n            </div>\n        </div>\n        \n        <div class=\"md:col-span-8 md:row-span-2 overflow-hidden rounded-[5rem] group relative border-[20px] border-marigold/10 rotate-1\" data-kid=\"57\">\n            <video src=\"https://videos.pexels.com/video-files/27684477/12204357_360_640_60fps.mp4\" poster=\"https://images.pexels.com/videos/27684477/pexels-photo-27684477.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" data-kid=\"58\"></video>\n            <div class=\"absolute bottom-12 left-12\" data-kid=\"59\">\n                <h3 class=\"font-anton text-8xl text-white drop-shadow-[0_0_20px_rgba(0,0,0,0.8)]\" data-kid=\"60\">FLORA VOID</h3>\n            </div>\n        </div>\n        \n        <div class=\"md:col-span-4 md:row-span-2 overflow-hidden rounded-t-[10rem] rounded-b-3xl group relative border-x-8 border-cyan-400/20\" data-kid=\"61\">\n            <img src=\"https://images.unsplash.com/photo-1618173745201-8e3bf8978acc?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" alt=\"Cool Dog\" data-kid=\"62\">\n            <div class=\"absolute inset-x-0 bottom-0 p-10 bg-gradient-to-t from-indigo-950 to-transparent translate-y-full group-hover:translate-y-0 transition-transform\" data-kid=\"63\">\n                <p class=\"font-mono text-cyan-400 text-sm font-bold tracking-widest\" data-kid=\"64\">// ARCHIVE_047: THE FIRST RESIDENT</p>\n            </div>\n        </div>\n        \n        <div class=\"md:col-span-8 md:row-span-1 glass-card rounded-[4rem] flex items-center justify-center p-12 overflow-hidden relative border-4 border-magenta-500/30\" data-kid=\"65\">\n            <div class=\"absolute -left-20 font-anton text-[12vw] text-white/5 whitespace-nowrap pointer-events-none select-none\" data-kid=\"66\">THUG IT OUT BRO. IT GETS BETTER.</div>\n            <div class=\"z-10 text-center\" data-kid=\"67\">\n                <h4 class=\"font-anton text-6xl lg:text-8xl mb-4 tracking-tighter text-marigold\" data-kid=\"68\">STAY HUNGRY.</h4>\n                <p class=\"font-mono text-cyan-400 text-xl tracking-[0.5em] uppercase\" data-kid=\"69\">The house provides. You build.</p>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"portal\" class=\"min-h-screen relative flex items-center justify-center overflow-hidden py-32\" data-kid=\"70\">\n    <div class=\"absolute inset-0 z-0\" data-kid=\"71\">\n        <video src=\"https://videos.pexels.com/video-files/33830781/14358690_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/33830781/pexels-photo-33830781.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-20 saturate-[2]\" data-kid=\"72\"></video>\n    </div>\n\n    <div class=\"absolute inset-0 bg-gradient-to-t from-[#0B0B2A] via-transparent to-[#0B0B2A] z-5\" data-kid=\"73\"></div>\n\n    <div class=\"relative z-10 w-full max-w-7xl px-10 flex flex-col lg:flex-row items-center justify-between gap-20\" data-kid=\"74\">\n        <div class=\"flex flex-col gap-8 text-left max-w-3xl\" data-kid=\"75\">\n            <h2 class=\"font-anton text-8xl lg:text-[12vw] leading-[0.85] uppercase tracking-tighter portal-title text-white\" data-kid=\"76\">JOIN THE<br data-kid=\"77\"><span class=\"text-marigold\" data-kid=\"78\">CULT</span> OF 47</h2>\n            <p class=\"font-mono text-cyan-400 text-xl lg:text-3xl uppercase tracking-[0.4em] distorted-text\" data-kid=\"79\">Applications are now live.</p>\n        </div>\n        \n        <div class=\"flex flex-col items-center lg:items-end gap-12\" data-kid=\"80\">\n            <button id=\"cta-btn\" class=\"portal-btn group relative px-20 py-12 bg-transparent border-8 border-marigold transition-all hover:bg-marigold duration-500 overflow-visible shadow-[0_0_50px_rgba(255,184,0,0.2)]\" data-kid=\"81\">\n                <span class=\"font-anton text-5xl lg:text-7xl text-marigold group-hover:text-indigo-950 transition-colors relative z-10\" data-kid=\"82\">ENTER</span>\n                <div class=\"absolute inset-0 bg-marigold blur-[80px] opacity-0 group-hover:opacity-40 transition-opacity\" data-kid=\"83\"></div>\n            </button>\n\n            <div class=\"grid grid-cols-3 gap-16\" data-kid=\"84\">\n                <div class=\"flex flex-col items-end\" data-kid=\"85\">\n                    <span class=\"font-mono text-white/60 text-xs uppercase tracking-widest mb-2\" data-kid=\"86\">Residents</span>\n                    <span class=\"font-anton text-5xl text-magenta-500\" data-kid=\"87\">47</span>\n                </div>\n                <div class=\"flex flex-col items-end\" data-kid=\"88\">\n                    <span class=\"font-mono text-white/60 text-xs uppercase tracking-widest mb-2\" data-kid=\"89\">Days</span>\n                    <span class=\"font-anton text-5xl text-cyan-400\" data-kid=\"90\">30</span>\n                </div>\n                <div class=\"flex flex-col items-end\" data-kid=\"91\">\n                    <span class=\"font-mono text-white/60 text-xs uppercase tracking-widest mb-2\" data-kid=\"92\">Vibe</span>\n                    <span class=\"font-anton text-5xl text-marigold\" data-kid=\"93\">∞</span>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div id=\"emoji-shower\" class=\"absolute inset-0 pointer-events-none overflow-hidden z-20\" data-kid=\"94\"></div>\n</section>\n\n\n<footer class=\"bg-black py-20 px-10 border-t border-white/5\" data-kid=\"95\">\n    <div class=\"flex flex-col lg:flex-row justify-between items-center gap-12\" data-kid=\"96\">\n        <div class=\"font-anton text-5xl tracking-tighter text-marigold\" data-kid=\"97\">HACK 47</div>\n        <div class=\"flex gap-12 font-mono text-sm uppercase tracking-widest text-white/50\" data-kid=\"98\">\n            <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"99\">Twitter</a>\n            <a href=\"#\" class=\"hover:text-marigold transition-colors\" data-kid=\"100\">Discord</a>\n            <a href=\"#\" class=\"hover:text-magenta-500 transition-colors\" data-kid=\"101\">Apply</a>\n        </div>\n        <div class=\"font-mono text-sm text-white/20 uppercase\" data-kid=\"102\">© 2025 Delhi Space Flora Collective</div>\n    </div>\n</footer>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"103\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"104\"></script>\n<script type=\"module\" data-kid=\"105\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    // GSAP Setup\n    gsap.registerPlugin(ScrollTrigger);\n    \n    // Smooth Scroll (Lenis)\n    const lenis = new Lenis({\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    });\n\n    lenis.on('scroll', ScrollTrigger.update);\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000);\n    });\n    gsap.ticker.lagSmoothing(0);\n\n    // Custom Cursor\n    const cursor = document.getElementById('cursor');\n    window.addEventListener('mousemove', (e) => {\n        gsap.to(cursor, {\n            x: e.clientX - 16,\n            y: e.clientY - 16,\n            duration: 0.1\n        });\n    });\n\n    // Hero Parallax\n    gsap.to(\".saturn-layer\", {\n        yPercent: 30,\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: \"#hero\",\n            start: \"top top\",\n            end: \"bottom top\",\n            scrub: true\n        }\n    });\n\n    gsap.to(\".title-layer\", {\n        yPercent: -20,\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: \"#hero\",\n            start: \"top top\",\n            end: \"bottom top\",\n            scrub: true\n        }\n    });\n\n    gsap.to(\".astronaut-layer img\", {\n        scale: 1.4,\n        yPercent: 10,\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: \"#hero\",\n            start: \"top top\",\n            end: \"bottom top\",\n            scrub: true\n        }\n    });\n\n    gsap.to(\".badge-left\", {\n        y: -100,\n        rotate: -30,\n        scrollTrigger: {\n            trigger: \"#hero\",\n            scrub: 1\n        }\n    });\n\n    gsap.to(\".badge-right\", {\n        y: 150,\n        rotate: 35,\n        scrollTrigger: {\n            trigger: \"#hero\",\n            scrub: 1\n        }\n    });\n\n    // Horizontal Scroll\n    const horizontalContainer = document.querySelector(\".horizontal-scroll-container\");\n    const horizontalTween = gsap.to(horizontalContainer, {\n        id: \"horizontal-scroll\",\n        x: () => -(horizontalContainer.scrollWidth - window.innerWidth),\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: \"#manifest-sticky\",\n            start: \"top top\",\n            end: () => `+=${horizontalContainer.scrollWidth}`,\n            scrub: 1,\n            pin: true,\n            anticipatePin: 1,\n        }\n    });\n\n    // Reveal animations for horizontal slides\n    gsap.utils.toArray(\".slide-title\").forEach(title => {\n        gsap.from(title, {\n            opacity: 0,\n            y: 100,\n            duration: 1,\n            scrollTrigger: {\n                trigger: title,\n                containerAnimation: horizontalTween,\n                start: \"left center\",\n            }\n        });\n    });\n\n    // Gallery Reveal\n    gsap.utils.toArray(\".vibe-card, [class*='md:col-span']\").forEach(card => {\n        gsap.from(card, {\n            opacity: 0,\n            y: 50,\n            scale: 0.9,\n            duration: 1,\n            scrollTrigger: {\n                trigger: card,\n                start: \"top 85%\",\n                toggleActions: \"play none none reverse\"\n            }\n        });\n    });\n\n    // CTA Emoji Shower\n    const ctaBtn = document.getElementById('cta-btn');\n    const shower = document.getElementById('emoji-shower');\n    const emojis = ['✨', '🚀', '🍄', '⚡️', '🪐', '🧬'];\n\n    ctaBtn.addEventListener('mouseenter', () => {\n        for(let i = 0; i < 20; i++) {\n            const emoji = document.createElement('div');\n            emoji.innerText = emojis[Math.floor(Math.random() * emojis.length)];\n            emoji.style.position = 'absolute';\n            emoji.style.left = '50%';\n            emoji.style.top = '50%';\n            emoji.style.fontSize = Math.random() * 20 + 20 + 'px';\n            emoji.style.pointerEvents = 'none';\n            shower.appendChild(emoji);\n\n            gsap.to(emoji, {\n                x: (Math.random() - 0.5) * 1000,\n                y: (Math.random() - 0.5) * 1000,\n                rotation: Math.random() * 720,\n                opacity: 0,\n                duration: 1.5,\n                ease: \"power2.out\",\n                onComplete: () => emoji.remove()\n            });\n        }\n    });\n</script>\n",
      "comments": [],
      "created": "2026-07-04T10:05:27.805808+00:00",
      "modified": "2026-07-04T10:05:27.805808+00:00",
      "id": "var_48fb8116c572"
    },
    "var_b092150699a3": {
      "type": "variant",
      "label": "Variant 3: Universal Overload",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 12078,
        "y": 0,
        "w": 1462,
        "h": 844
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&family=Archivo+Black&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --color-purple: #2D00F7;\n    --color-yellow: #F2E30C;\n    --color-navy: #0A1128;\n    --color-white: #FFFFFF;\n    --color-pink: #FF007F;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--color-navy);\n    color: var(--color-white);\n    font-family: 'Space_Grotesk', sans-serif;\n    overflow-x: clip;\n  }\n\n  .font-archivo { font-family: 'Archivo Black', sans-serif; }\n  .font-space { font-family: 'Space Grotesk', sans-serif; }\n\n  /* LocalHost Style Cards */\n  .lh-card {\n    background: var(--color-white);\n    border: 2px solid black;\n    box-shadow: 12px 12px 0px 0px rgba(0,0,0,1);\n    color: black;\n    position: relative;\n    z-index: 40;\n  }\n\n  /* Animations */\n  @keyframes rotate-slow {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n  .animate-rotate-slow {\n    animation: rotate-slow 20s linear infinite;\n  }\n\n  .animate-pulse-glow {\n    animation: pulse-glow 3s ease-in-out infinite;\n  }\n  @keyframes pulse-glow {\n    0%, 100% { filter: drop-shadow(0 0 20px rgba(242,227,12,0.4)); }\n    50% { filter: drop-shadow(0 0 60px rgba(242,227,12,0.8)); }\n  }\n\n  /* Custom Cursor - Optional but fits the maximalist vibe */\n  .custom-cursor {\n    width: 20px;\n    height: 20px;\n    background: var(--color-yellow);\n    border-radius: 50%;\n    position: fixed;\n    pointer-events: none;\n    z-index: 9999;\n    mix-blend-difference: exclusion;\n  }\n\n  /* Grid lines for spots */\n  .spots-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n  }\n  @media (min-width: 1024px) {\n    .spots-grid { grid-template-columns: repeat(8, 1fr); }\n  }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n    \n    \n    <section class=\"relative min-h-screen flex flex-col items-center justify-center p-8 overflow-hidden bg-black\" data-kid=\"3\">\n      \n      <video src=\"https://videos.pexels.com/video-files/33549523/14265300_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/33549523/pexels-photo-33549523.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover opacity-50 z-0\" data-kid=\"4\">\n      </video>\n      \n      \n      <div class=\"absolute inset-0 pointer-events-none overflow-hidden z-10\" data-kid=\"5\">\n        \n        <img src=\"https://images.unsplash.com/photo-1451187580459-43490279c0fa?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTAwNDR8MHwxfHNlYXJjaHwxfHxnbG93aW5nJTIwZWFydGglMjBmcm9tJTIwc3BhY2V8ZW58MHx8fHwxNzgzMTYwNjIxfDA&ixlib=rb-4.1.0&q=85&auto=format&w=1400\" alt=\"NASA on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"hero-earth absolute bottom-0 lg:bottom-[5%] left-1/2 -translate-x-1/2 w-full max-w-[1400px] opacity-100\" data-kid=\"6\">\n        \n        \n        <img src=\"https://images.pexels.com/photos/11967924/pexels-photo-11967924.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Eugene Golovesov on Pexels\" decoding=\"async\" loading=\"lazy\" class=\"hero-flowers absolute bottom-[15%] lg:bottom-[25%] left-1/2 -translate-x-1/2 w-[600px] lg:w-[900px] mix-blend-screen opacity-90 z-20\" data-kid=\"7\">\n      </div>\n\n      \n      <div class=\"relative z-30 w-full max-w-7xl flex flex-col gap-6 lg:gap-12 mt-[-100px]\" data-kid=\"8\">\n        <div class=\"flex flex-wrap gap-4 lg:gap-8 items-start\" data-kid=\"9\">\n          <div class=\"lh-card p-8 lg:p-14 max-w-2xl transform lg:-rotate-2\" data-kid=\"10\">\n            <h1 class=\"text-6xl lg:text-9xl font-archivo leading-none tracking-tighter\" data-kid=\"11\">HACK47</h1>\n            <p class=\"text-lg lg:text-2xl font-bold mt-4 lg:mt-6 border-t-2 border-black pt-4 uppercase\" data-kid=\"12\">Universal Overload v1.0</p>\n          </div>\n          \n          <div class=\"lh-card p-4 lg:p-6 bg-[var(--color-yellow)] transform lg:rotate-3 mt-4 lg:mt-8\" data-kid=\"13\">\n            <p class=\"text-xl lg:text-3xl font-archivo tracking-tighter\" data-kid=\"14\">SEPT 15 — OCT 15</p>\n          </div>\n          \n          <div class=\"lh-card p-4 bg-[var(--color-pink)] text-white transform lg:-rotate-6 mt-12 hidden lg:block border-white\" data-kid=\"15\">\n             <p class=\"text-xs font-black uppercase\" data-kid=\"16\">Delhi Hacker House</p>\n          </div>\n        </div>\n\n        <div class=\"self-end lh-card p-6 lg:p-10 max-w-sm transform lg:rotate-1\" data-kid=\"17\">\n          <p class=\"text-xl lg:text-3xl font-black leading-tight\" data-kid=\"18\">16 BUILDERS.<br data-kid=\"19\">30 DAYS.<br data-kid=\"20\">BUILD CRAZY SHIT.</p>\n          <div class=\"mt-6 flex items-center gap-4\" data-kid=\"21\">\n             <div class=\"w-10 h-10 lg:w-14 lg:h-14 bg-black rounded-full flex items-center justify-center text-white\" data-kid=\"22\">\n                <i class=\"ti ti-rocket text-xl lg:text-3xl\" data-kid=\"23\"></i>\n             </div>\n             <span class=\"text-lg lg:text-xl font-black uppercase tracking-widest\" data-kid=\"24\">JOIN OR DIE</span>\n          </div>\n        </div>\n      </div>\n      \n      \n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/viscious-speed/abstract-118.svg\" style=\"color: var(--color-pink);\" class=\"absolute top-20 right-20 w-32 h-32 opacity-30 animate-rotate-slow\" data-kid=\"25\">\n    </section>\n\n    \n    <section class=\"bg-[var(--color-purple)] py-24 lg:py-48 relative overflow-hidden\" data-kid=\"26\">\n      \n      <div class=\"marquee-container absolute top-1/2 left-0 w-full -translate-y-1/2 flex whitespace-nowrap overflow-hidden pointer-events-none\" data-kid=\"27\">\n        <div class=\"marquee-text text-[25vw] font-archivo text-white/30 leading-none uppercase select-none\" data-kid=\"28\">\n          BUILD SOME CRAZY SHIT • BUILD SOME CRAZY SHIT •\n        </div>\n      </div>\n\n      <div class=\"relative z-10 max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16\" data-kid=\"29\">\n        <div class=\"manifesto-col flex flex-col gap-8 mt-12\" data-kid=\"30\">\n          <div class=\"w-24 h-2 bg-white\" data-kid=\"31\"></div>\n          <h3 class=\"text-5xl lg:text-6xl font-archivo leading-none\" data-kid=\"32\">THE ETHOS</h3>\n          <p class=\"text-xl lg:text-2xl text-white leading-relaxed font-bold\" data-kid=\"33\">Hack47 is a sandbox for the visionary, the obsessed, and the slightly mad. We don't build features, we build entire worlds.</p>\n        </div>\n\n        <div class=\"manifesto-col flex flex-col gap-8 mt-12\" data-kid=\"34\">\n          <div class=\"w-24 h-2 bg-[var(--color-yellow)]\" data-kid=\"35\"></div>\n          <h3 class=\"text-5xl lg:text-6xl font-archivo leading-none\" data-kid=\"36\">THE LAB</h3>\n          <p class=\"text-xl lg:text-2xl text-white leading-relaxed font-bold\" data-kid=\"37\">Collisions of biology and silicon. High-tech equipment meets surrealist art. Delhi's concrete jungle transformed into a digital oasis.</p>\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/sbed/slow-blob.svg\" style=\"color: var(--color-yellow);\" class=\"parallax-blob w-40 lg:w-56 h-40 lg:h-56 opacity-100\" data-kid=\"38\">\n        </div>\n\n        <div class=\"manifesto-col flex flex-col gap-8 mt-12\" data-kid=\"39\">\n          <div class=\"w-24 h-2 bg-[var(--color-pink)]\" data-kid=\"40\"></div>\n          <h3 class=\"text-5xl lg:text-6xl font-archivo leading-none\" data-kid=\"41\">THE VOID</h3>\n          <p class=\"text-xl lg:text-2xl text-white leading-relaxed font-bold\" data-kid=\"42\">Step into the dark. Focus is the only currency that matters here. 16 minds, 30 days, zero distractions.</p>\n          <div class=\"parallax-planet bg-white/30 w-24 lg:w-32 h-24 lg:h-32 rounded-full border-2 border-white/40 backdrop-blur-md flex items-center justify-center shadow-[0_0_50px_rgba(255,255,255,0.3)]\" data-kid=\"43\">\n            <i class=\"ti ti-planet text-5xl lg:text-6xl text-white\" data-kid=\"44\"></i>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"bg-black py-32 px-8 overflow-hidden font-space\" data-kid=\"45\">\n      <div class=\"max-w-7xl mx-auto\" data-kid=\"46\">\n        <div class=\"flex justify-between items-end mb-16 border-b border-white/20 pb-8\" data-kid=\"47\">\n           <div data-kid=\"48\">\n              <h2 class=\"text-white text-6xl font-archivo tracking-tighter uppercase\" data-kid=\"49\">The 16 Nuclei</h2>\n              <p class=\"text-white/40 mt-2 font-mono uppercase tracking-[0.3em]\" data-kid=\"50\">Status: Scanning Orbit...</p>\n           </div>\n           <div class=\"hidden md:block lh-card p-4 bg-black text-white border-white transform -rotate-1\" data-kid=\"51\">\n              <span class=\"text-sm font-bold\" data-kid=\"52\">LIMITED SLOTS AVAILABLE</span>\n           </div>\n        </div>\n\n        <div class=\"spots-grid border-t border-l border-white/30 bg-[rgba(255,255,255,0.02)] lg:mx-12\" data-kid=\"53\">\n          \n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"54\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"55\">H-1</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"56\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/alien.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"57\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"58\">ORBIT-01</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"59\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"60\">H-2</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"61\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/blossom.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"62\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"63\">FLOWER-X</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"64\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"65\">H-3</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"66\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/water-wave.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"67\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"68\">SEA-03</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"69\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"70\">H-4</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"71\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/alien-monster.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"72\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"73\">VOID-04</span>\n          </div>\n          \n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden bg-white/10\" data-kid=\"74\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"75\">L-5</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"76\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/picture.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"77\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"78\">LOCKED</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"79\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"80\">H-6</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"81\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/tsunami.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"82\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"83\">TIDE-06</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"84\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"85\">H-7</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"86\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/goblin.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"87\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"88\">DEMON-07</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden bg-white/10\" data-kid=\"89\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"90\">L-8</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"91\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/satellite.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"92\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"93\">LOCKED</span>\n          </div>\n          \n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"94\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"95\">H-9</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"96\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/person.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"97\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"98\">CREATOR-X</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"99\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"100\">H-10</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"101\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/moai.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"102\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"103\">STONE-10</span>\n          </div>\n          <div class=\"aspect-square border-r border-b border-white/10 opacity-20 bg-gradient-to-br from-white/10 to-transparent\" data-kid=\"104\"></div>\n          <div class=\"aspect-square border-r border-b border-white/10 opacity-20 bg-gradient-to-br from-white/10 to-transparent\" data-kid=\"105\"></div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden bg-white/10\" data-kid=\"106\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"107\">L-13</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"108\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/c.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"109\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"110\">RESERVED</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden\" data-kid=\"111\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"112\">H-14</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"113\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/mobile-phone.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"114\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"115\">NODE-14</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden bg-pink-500/20\" data-kid=\"116\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"117\">H-15</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"118\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/tardis.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"119\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"120\">TIME-15</span>\n          </div>\n          <div class=\"spot-item aspect-square border-r border-b border-white/30 flex flex-col items-center justify-center relative group cursor-crosshair overflow-hidden bg-yellow-500/20\" data-kid=\"121\">\n            <span class=\"absolute top-2 left-2 text-[8px] font-mono text-white/50 group-hover:text-black\" data-kid=\"122\">H-16</span>\n            <div class=\"spot-reveal absolute inset-0 opacity-0 group-hover:opacity-100 flex items-center justify-center\" data-kid=\"123\"><img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/mermaid.svg\" class=\"w-12 h-12 lg:w-16 lg:h-16\" data-kid=\"124\"></div>\n            <span class=\"text-xs font-black group-hover:opacity-0\" data-kid=\"125\">FINAL-16</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"relative w-full min-h-screen overflow-hidden bg-black\" data-kid=\"126\">\n      <div class=\"absolute inset-0 flex flex-col lg:flex-row h-full\" data-kid=\"127\">\n        \n        <div class=\"relative w-full h-full overflow-hidden lg:[clip-path:polygon(0_0,100%_0,60%_100%,0%_100%)] z-10\" data-kid=\"128\">\n          <img src=\"https://images.unsplash.com/photo-1501436513145-30f24e19fcc8?auto=format&w=1200&q=80&fit=crop\" alt=\"Linus Nylund on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"absolute inset-0 w-full h-full object-cover\" data-kid=\"129\">\n          <div class=\"absolute inset-0 bg-blue-500/20 backdrop-blur-xs\" data-kid=\"130\"></div>\n          <div class=\"relative z-10 h-full flex flex-col items-start justify-center p-12 lg:p-24 text-left\" data-kid=\"131\">\n            <h2 class=\"text-8xl lg:text-[10vw] font-archivo text-white drop-shadow-[0_0_30px_rgba(255,255,255,0.5)]\" data-kid=\"132\">CALM</h2>\n            <p class=\"text-2xl text-white mt-8 max-w-md font-black uppercase tracking-widest leading-none bg-black px-4 py-2\" data-kid=\"133\">The natural rhythm of deep work.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 lg:left-[40%] w-full lg:w-[60%] h-full bg-[#0A1128] overflow-hidden\" data-kid=\"134\">\n          <div class=\"absolute inset-0 opacity-20\" data-kid=\"135\">\n             <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/circuitry.svg\" class=\"w-full h-full object-cover invert\" data-kid=\"136\">\n          </div>\n          <div class=\"relative z-10 h-full flex flex-col items-end justify-center p-12 lg:p-24 text-right\" data-kid=\"137\">\n            <h2 class=\"text-8xl lg:text-[10vw] font-archivo text-[var(--color-yellow)] drop-shadow-[0_0_30px_rgba(242,227,12,0.3)]\" data-kid=\"138\">CHAOS</h2>\n            <p class=\"text-2xl text-white/70 mt-8 max-w-md font-black uppercase tracking-widest leading-none bg-[var(--color-purple)] px-4 py-2\" data-kid=\"139\">High intensity silicon madness.</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute top-1/2 left-1/2 lg:left-[58%] -translate-x-1/2 -translate-y-1/2 z-30\" data-kid=\"140\">\n        <div class=\"w-48 h-48 lg:w-56 lg:h-56 rounded-full bg-white flex items-center justify-center border-8 border-black shadow-[0_0_100px_rgba(255,255,255,0.6)] animate-rotate-slow\" data-kid=\"141\">\n            <i class=\"ti ti-atom-2 text-8xl lg:text-[100px] text-black\" data-kid=\"142\"></i>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"relative bg-black pt-32 pb-24 px-8 flex flex-col items-center justify-center overflow-hidden\" data-kid=\"143\">\n      \n      <div class=\"absolute bottom-[-20%] left-1/2 -translate-x-1/2 w-[180vw] h-[100vw] rounded-full bg-radial-[at_center_top] from-[#2D00F7]/60 via-transparent to-transparent opacity-80 z-0\" data-kid=\"144\"></div>\n      \n      <div class=\"relative z-10 text-center flex flex-col items-center\" data-kid=\"145\">\n        <h2 class=\"text-white text-7xl lg:text-[10vw] font-archivo leading-none tracking-tighter uppercase mb-6\" data-kid=\"146\">Join the orbit.</h2>\n        \n        \n        <div class=\"relative group cursor-pointer mb-12\" data-kid=\"147\">\n          <svg class=\"w-64 h-64 lg:w-80 lg:h-80 absolute -inset-0 -translate-x-0 -translate-y-0 group-hover:rotate-180 transition-transform duration-1000 ease-in-out\" viewBox=\"0 0 200 200\" data-kid=\"148\">\n            <path id=\"footerCurve\" d=\"M 100, 100 m -85, 0 a 85,85 0 1,0 170,0 a 85,85 0 1,0 -170,0\" fill=\"transparent\" data-kid=\"149\"></path>\n            <text class=\"text-[10px] font-bold fill-white tracking-[0.4em] uppercase\" data-kid=\"150\">\n              <textPath xlink:href=\"#footerCurve\" data-kid=\"151\">\n                Apply for Hack47 • Apply for Hack47 • Apply for Hack47 •\n              </textPath>\n            </text>\n          </svg>\n          \n          <div class=\"w-32 h-32 lg:w-40 lg:h-40 rounded-full bg-[var(--color-yellow)] flex items-center justify-center shadow-[0_0_40px_rgba(242,227,12,0.5)] group-hover:shadow-[0_0_100px_rgba(242,227,12,1)] transition-all animate-pulse-glow m-16 lg:m-20\" data-kid=\"152\">\n            <i class=\"ti ti-arrow-up-right text-5xl lg:text-6xl text-black transform group-hover:translate-x-2 group-hover:-translate-y-2 transition-transform\" data-kid=\"153\"></i>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 w-full max-w-7xl pt-24 border-t border-white/20 mt-12\" data-kid=\"154\">\n          <div class=\"text-left\" data-kid=\"155\">\n             <h4 class=\"text-white font-archivo text-xl mb-4\" data-kid=\"156\">LOCATION</h4>\n             <p class=\"text-white/70\" data-kid=\"157\">Hauz Khas, New Delhi<br data-kid=\"158\">India, Earth</p>\n          </div>\n          <div class=\"text-center\" data-kid=\"159\">\n             <h4 class=\"text-white font-archivo text-xl mb-4\" data-kid=\"160\">STATUS</h4>\n             <p class=\"text-[var(--color-yellow)] animate-pulse font-black\" data-kid=\"161\">APPLICATIONS OPEN</p>\n          </div>\n          <div class=\"text-right\" data-kid=\"162\">\n             <h4 class=\"text-white font-archivo text-xl mb-4\" data-kid=\"163\">SOCIAL</h4>\n             <div class=\"flex justify-end gap-6 text-2xl text-white\" data-kid=\"164\">\n                <a href=\"#\" class=\"hover:text-[var(--color-yellow)] transition-colors\" data-kid=\"165\"><i class=\"ti ti-brand-x\" data-kid=\"166\"></i></a>\n                <a href=\"#\" class=\"hover:text-[var(--color-yellow)] transition-colors\" data-kid=\"167\"><i class=\"ti ti-brand-instagram\" data-kid=\"168\"></i></a>\n                <a href=\"#\" class=\"hover:text-[var(--color-yellow)] transition-colors\" data-kid=\"169\"><i class=\"ti ti-brand-github\" data-kid=\"170\"></i></a>\n             </div>\n          </div>\n        </div>\n\n        <p class=\"text-white/40 mt-24 font-mono text-xs uppercase tracking-[0.5em]\" data-kid=\"171\">© 2024 HACK47 • UNIVERSAL OVERLOAD</p>\n      </div>\n    </footer>\n\n  </div>\n</div>\n\n<div class=\"custom-cursor hidden md:block\" data-kid=\"172\"></div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"173\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"174\"></script>\n<script type=\"module\" data-kid=\"175\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Initialize Lenis\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Custom Cursor\n  const cursor = document.querySelector('.custom-cursor');\n  window.addEventListener('mousemove', e => {\n    gsap.to(cursor, {\n      x: e.clientX,\n      y: e.clientY,\n      duration: 0.1\n    });\n  });\n\n  // Hero Parallax\n  gsap.to(\".hero-earth\", {\n    yPercent: -20,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \"section\",\n      start: \"top top\",\n      end: \"bottom top\",\n      scrub: true\n    }\n  });\n\n  gsap.to(\".hero-flowers\", {\n    yPercent: -40,\n    scale: 1.5,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \"section\",\n      start: \"top top\",\n      end: \"bottom top\",\n      scrub: true\n    }\n  });\n\n  // Manifesto Marquee\n  gsap.to(\".marquee-text\", {\n    xPercent: -50,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \".marquee-container\",\n      start: \"top bottom\",\n      end: \"bottom top\",\n      scrub: 1\n    }\n  });\n\n  // Manifesto Columns Parallax\n  gsap.utils.toArray('.manifesto-col').forEach((col, i) => {\n    gsap.from(col, {\n      y: 100 * (i + 1),\n      opacity: 0.5,\n      scrollTrigger: {\n        trigger: col,\n        start: \"top bottom\",\n        end: \"center center\",\n        scrub: true\n      }\n    });\n  });\n\n  // Floating Blobs\n  gsap.to(\".parallax-blob\", {\n    y: -180,\n    rotation: 90,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \".parallax-blob\",\n      scrub: 1,\n      start: \"top bottom\",\n      end: \"bottom top\"\n    }\n  });\n\n  gsap.to(\".parallax-planet\", {\n    y: 120,\n    x: 60,\n    rotation: -45,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \".parallax-planet\",\n      scrub: 1,\n      start: \"top bottom\",\n      end: \"bottom top\"\n    }\n  });\n\n  // Spot Grid Hover Color Cycling (Optimized with GSAP Timeline)\n  const spots = document.querySelectorAll('.spot-item');\n  spots.forEach(spot => {\n    const tl = gsap.timeline({ paused: true, repeat: -1 });\n    tl.to(spot, { backgroundColor: '#F2E30C', duration: 0.2, color: '#000' })\n      .to(spot, { backgroundColor: '#FF007F', duration: 0.2 })\n      .to(spot, { backgroundColor: '#00FF00', duration: 0.2 })\n      .to(spot, { backgroundColor: '#FFFFFF', duration: 0.2 });\n\n    spot.addEventListener('mouseenter', () => {\n      tl.play();\n    });\n    spot.addEventListener('mouseleave', () => {\n      tl.pause();\n      gsap.to(spot, { backgroundColor: 'transparent', duration: 0.3, color: '#fff', clearProps: 'backgroundColor,color' });\n    });\n  });\n\n</script>\n",
      "comments": [],
      "created": "2026-07-04T10:24:15.108531+00:00",
      "modified": "2026-07-04T10:24:15.108531+00:00",
